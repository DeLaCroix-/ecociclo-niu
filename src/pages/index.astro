---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Servicios from '../components/Servicios.astro';
import Lideres from '../components/Lideres.astro';
import Proceso from '../components/Proceso.astro';
import CtaSection from '../components/CtaSection.astro';
import Faq from '../components/Faq.astro';
import Testimonios from '../components/Testimonios.astro';
---

<Layout 
  title="Gestión de Residuos en Barcelona"
  description="Expertos en gestión de residuos en Barcelona. Soluciones rápidas, certificadas y sostenibles para empresas. ¡Infórmate aquí!"
  canonical="https://ecociclonew.netlify.app/"
>

<!-- ===== HERO (exact reproduction: gspb_row-id-gsbp-87fe861) ===== -->
<Hero />

<!-- ===== FILOSOFÍA (matches original: y=727, h=734, padding 50px 0 40px) ===== -->
<section class="filosofia-section">
  <div class="container-site">
    <span class="section-label">Nuestra Filosofía</span>
    <h2>Más que una limpieza, una empresa de gestión ambiental en BARCELONA</h2>
    
    <div class="filosofia-grid">
      <div class="filosofia-card">
        <img src="/images/hero-overlay.webp" alt="" class="filosofia-icon" width="60" height="60" />
        <div>
          <p class="filosofia-pill">Residuo Cero</p>
          <p class="filosofia-desc">Trabajamos para minimizar el impacto ambiental, asegurando que cada residuo reciba el tratamiento adecuado.</p>
        </div>
      </div>
      <div class="filosofia-card">
        <img src="/images/hero-overlay.webp" alt="" class="filosofia-icon" width="60" height="60" />
        <div>
          <p class="filosofia-pill">Garantía Legal Certificada</p>
          <p class="filosofia-desc">Toda la documentación legal necesaria para que cumplas con la normativa vigente.</p>
        </div>
      </div>
      <div class="filosofia-card">
        <img src="/images/hero-overlay.webp" alt="" class="filosofia-icon" width="60" height="60" />
        <div>
          <p class="filosofia-pill">Acción en 24/48h</p>
          <p class="filosofia-desc">Respuesta inmediata. Nos adaptamos a tu urgencia para liberar tu espacio cuanto antes.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== SERVICIOS (exact reproduction: gspb_row-id-gsbp-b0a856b) ===== -->
<Servicios />

<!-- ===== PROCESO (exact reproduction: gspb_row-id-gsbp-e906f9a, y=2368, h=771) ===== -->
<Proceso />

<!-- ===== LÍDERES (exact: gspb_row-id-gsbp-022f526, y=3139, h=847) ===== -->
<Lideres />

<!-- ===== CTA (exact: gspb_row-id-gsbp-9ffae62 + gsbp-423aa83, y=3986, h=580, bg #00312D) ===== -->
<CtaSection />

<!-- ===== FAQ (exact: gspb_row-id-gsbp-b8efaa8, y=4566, h=914, 8-question accordion) ===== -->
<Faq />

<!-- ===== TESTIMONIOS (exact: gspb_row-id-gsbp-a640774, y=5480, h=334, Trustindex carousel) ===== -->
<Testimonios />

</Layout>

<style>
  /* ===== FILOSOFÍA ===== */
  .filosofia-section {
    padding: 50px 0 40px;
  }

  .section-label {
    display: inline-block;
    color: #65C132;
    font-family: 'SoinSans', sans-serif;
    font-weight: 500;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 12px;
  }

  .filosofia-section h2 {
    font-size: 35px;
    color: #192a3d;
    margin-bottom: 40px;
    max-width: 800px;
  }

  .filosofia-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }

  .filosofia-card {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 20px;
    border-radius: 12px;
    background: #f8faf9;
  }

  .filosofia-icon {
    width: 60px;
    height: 60px;
    border-radius: 12px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .filosofia-pill {
    font-family: 'SoinSans', sans-serif;
    font-weight: 500;
    font-size: 14px;
    color: #00312D;
    margin-bottom: 6px;
  }

  .filosofia-desc {
    font-size: 14px;
    color: #666;
    line-height: 1.5;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 900px) {
    .filosofia-grid { grid-template-columns: 1fr; }
    
    .filosofia-section h2 { font-size: 26px; }
  }
</style>

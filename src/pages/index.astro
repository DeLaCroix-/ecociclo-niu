---
import Layout from '../layouts/Layout.astro';

const services = [
  { icon: '🏭', title: 'Vaciado de naves', desc: 'Vaciado de naves industriales, pisos y locales en Barcelona. Servicio rápido y profesional.', href: '/servicios/vaciado-de-naves-industriales-pisos-y-locales-en-barcelona' },
  { icon: '🏠', title: 'Limpieza de Diógenes', desc: 'Limpieza de Diógenes en Barcelona. Tratamiento especializado con máxima discreción.', href: '/servicios/limpieza-de-diogenes-en-barcelona' },
  { icon: '🔄', title: 'Trasvases', desc: 'Trasvases y acondicionamiento de residuos peligrosos. Manipulación segura.', href: '/servicios/acondicionamiento-de-residuos-peligrosos-en-barcelona' },
  { icon: '🗑️', title: 'Residuos Banales', desc: 'Gestión de residuos banales en Barcelona. Recogida y transporte eficiente.', href: '/servicios/gestion-de-residuos-banales-en-barcelona' },
  { icon: '⚠️', title: 'Residuos Especiales Sólidos', desc: 'Transporte de residuos especiales sólidos con todas las garantías de seguridad.', href: '/servicios/transporte-de-residuos-especiales-solidos-en-barcelona' },
  { icon: '🧪', title: 'Residuos Especiales Líquidos', desc: 'Transporte de residuos especiales líquidos. Gestión integral conforme a normativa.', href: '/servicios/transporte-de-residuos-especiales-liquidos-en-barcelona' },
  { icon: '🧱', title: 'Fibrocemento', desc: 'Retirada de fibrocemento en Barcelona. Desamiantado profesional y seguro.', href: '/servicios/retirada-de-fibrocemento-en-barcelona' },
  { icon: '🌿', title: 'Limpieza de Terrenos', desc: 'Limpieza de terrenos y parcelas. Desbroce y acondicionamiento de espacios.', href: '/servicios/limpieza-de-terrenos-y-parcelas-en-barcelona' },
];

const faqs = [
  { q: '¿Qué tipos de residuos gestionáis?', a: 'Gestionamos todo tipo de residuos: banales, especiales sólidos y líquidos, fibrocemento, residuos industriales, comerciales y domiciliarios. Contamos con las autorizaciones necesarias para cada tipo de residuo.' },
  { q: '¿Cuánto tardáis en realizar un servicio?', a: 'El tiempo de ejecución depende del volumen y tipo de residuo. Un vaciado estándar puede realizarse en 1-3 días. Para servicios urgentes, contacta con nosotros y te daremos una estimación personalizada.' },
  { q: '¿Ofrecéis presupuesto sin compromiso?', a: 'Sí, todos nuestros presupuestos son gratuitos y sin compromiso. Evaluamos tu caso y te proporcionamos una estimación detallada antes de cualquier trabajo.' },
  { q: '¿Estáis autorizados para gestionar residuos peligrosos?', a: 'Sí, Ecociclo cuenta con todas las autorizaciones y licencias necesarias para la gestión de residuos peligrosos y no peligrosos, cumpliendo estrictamente la normativa vigente.' },
  { q: '¿En qué zonas de Barcelona trabajáis?', a: 'Damos servicio en toda el área metropolitana de Barcelona y provincia. Consulta con nosotros si tu ubicación está dentro de nuestra zona de cobertura.' },
  { q: '¿Cómo se realiza el transporte de residuos especiales líquidos?', a: 'El transporte se realiza en vehículos especialmente acondicionados con sistemas de contención, cumpliendo toda la normativa ADR para mercancías peligrosas.' },
];

---
<Layout 
  title="Gestión de residuos en Barcelona"
  description="Ecociclo: empresa líder en gestión de residuos en Barcelona para empresas, industria y locales. Vaciado de naves, limpieza de Diógenes, retirada de fibrocemento y más."
  canonical="https://ecociclo-niu.netlify.app/"
>

<!-- Hero Section -->
<section class="relative bg-gradient-to-br from-[#36611C] via-[#00312D] to-[#192a3d] text-white py-20 md:py-32 overflow-hidden">
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-10 left-10 w-72 h-72 bg-[#65C132] rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 right-10 w-96 h-96 bg-[#65C132] rounded-full blur-3xl"></div>
  </div>
  <div class="container-site relative z-10">
    <div class="max-w-3xl">
      <h1 class="text-3xl md:text-5xl font-bold leading-tight mb-6">
        Gestión de residuos en Barcelona para empresas, industria y locales
      </h1>
      <p class="text-lg md:text-xl text-gray-200 mb-8 leading-relaxed">
        Somos líderes en gestión integral de residuos en Barcelona. Ofrecemos soluciones rápidas, seguras y profesionales para liberar tus espacios de cualquier tipo de residuo.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/contacto" class="bg-[#65C132] text-white px-8 py-4 rounded-full font-bold text-lg hover:bg-[#45891E] transition-colors text-center shadow-lg">
          Solicitar presupuesto
        </a>
        <a href="/servicios-de-gestion-ambiental" class="border-2 border-white text-white px-8 py-4 rounded-full font-bold text-lg hover:bg-white hover:text-[#36611C] transition-colors text-center">
          Ver servicios
        </a>
      </div>
    </div>
  </div>
</section>

<!-- What We Do Section -->
<section class="py-20 bg-white">
  <div class="container-site">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-[#192a3d] mb-4">¿Qué hacemos en ecociclo?</h2>
      <p class="text-gray-600 text-lg max-w-2xl mx-auto">Ofrecemos una amplia gama de servicios de gestión ambiental adaptados a las necesidades de empresas, industrias y particulares en Barcelona.</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {services.map((service) => (
        <a href={service.href} class="group bg-white border border-gray-100 rounded-xl p-6 shadow-sm hover:shadow-lg hover:border-[#65C132] transition-all duration-300 flex flex-col items-center text-center">
          <span class="text-4xl mb-4 group-hover:scale-110 transition-transform">{service.icon}</span>
          <h3 class="font-bold text-[#192a3d] mb-2 group-hover:text-[#36611C] transition-colors">{service.title}</h3>
          <p class="text-gray-600 text-sm leading-relaxed">{service.desc}</p>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- 3 Steps Section -->
<section class="py-20 bg-[#EAFDE7]">
  <div class="container-site">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-[#192a3d] mb-4">Tu espacio libre de residuos en tres pasos</h2>
      <p class="text-gray-600 text-lg">Así de fácil es trabajar con nosotros</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="text-center">
        <div class="w-20 h-20 bg-[#36611C] text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6 shadow-lg">1</div>
        <h3 class="text-xl font-bold text-[#192a3d] mb-3">Solicita tu presupuesto</h3>
        <p class="text-gray-600">Cuéntanos qué necesitas. Te ofrecemos un presupuesto sin compromiso en menos de 24 horas.</p>
      </div>
      <div class="text-center">
        <div class="w-20 h-20 bg-[#45891E] text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6 shadow-lg">2</div>
        <h3 class="text-xl font-bold text-[#192a3d] mb-3">Realizamos el servicio</h3>
        <p class="text-gray-600">Nuestro equipo profesional se encarga de todo: recogida, transporte y gestión de residuos.</p>
      </div>
      <div class="text-center">
        <div class="w-20 h-20 bg-[#65C132] text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6 shadow-lg">3</div>
        <h3 class="text-xl font-bold text-[#192a3d] mb-3">Tu espacio, libre</h3>
        <p class="text-gray-600">Disfruta de un espacio limpio y libre de residuos, con certificación de gestión responsable.</p>
      </div>
    </div>
  </div>
</section>

<!-- Stats Section -->
<section class="py-20 bg-[#00312D] text-white">
  <div class="container-site">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Líderes en gestión de residuos en Barcelona</h2>
      <p class="text-gray-300 text-lg">Nuestra experiencia nos avala</p>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      <div>
        <div class="text-4xl md:text-5xl font-bold text-[#65C132] mb-2">+2.500</div>
        <p class="text-gray-300">Servicios realizados</p>
      </div>
      <div>
        <div class="text-4xl md:text-5xl font-bold text-[#65C132] mb-2">+10</div>
        <p class="text-gray-300">Años de experiencia</p>
      </div>
      <div>
        <div class="text-4xl md:text-5xl font-bold text-[#65C132] mb-2">98%</div>
        <p class="text-gray-300">Clientes satisfechos</p>
      </div>
      <div>
        <div class="text-4xl md:text-5xl font-bold text-[#65C132] mb-2">24h</div>
        <p class="text-gray-300">Respuesta rápida</p>
      </div>
    </div>
  </div>
</section>

<!-- FAQ Section -->
<section class="py-20 bg-white">
  <div class="container-site">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-[#192a3d] mb-4">Preguntas frecuentes</h2>
      <p class="text-gray-600 text-lg">Resolvemos tus dudas</p>
    </div>
    <div class="max-w-3xl mx-auto space-y-4">
      {faqs.map((faq, i) => (
        <div class="border border-gray-200 rounded-lg overflow-hidden">
          <details class="group">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer hover:bg-[#EAFDE7] transition-colors font-semibold text-[#192a3d]">
              {faq.q}
              <span class="text-[#65C132] text-xl group-open:rotate-180 transition-transform">▾</span>
            </summary>
            <div class="px-6 py-4 bg-gray-50 text-gray-600 text-sm leading-relaxed border-t border-gray-100">
              {faq.a}
            </div>
          </details>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CTA Section -->
<section class="py-20 bg-gradient-to-r from-[#36611C] to-[#45891E] text-white">
  <div class="container-site text-center">
    <h2 class="text-3xl md:text-4xl font-bold mb-4">Recupera tu espacio hoy mismo</h2>
    <p class="text-lg text-gray-100 mb-8 max-w-2xl mx-auto">Solicita tu presupuesto gratuito sin compromiso. Nuestro equipo te responderá en menos de 24 horas.</p>
    <a href="/contacto" class="inline-block bg-white text-[#36611C] px-10 py-4 rounded-full font-bold text-lg hover:bg-[#EAFDE7] transition-colors shadow-lg">
      Solicitar presupuesto →
    </a>
  </div>
</section>

</Layout>

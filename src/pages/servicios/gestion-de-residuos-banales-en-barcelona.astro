---
import Layout from '../../layouts/Layout.astro';

const faqs = [
  { q: '¿Qué son los residuos banales?', a: 'Los residuos banales (también llamados asimilables a urbanos) son aquellos que no presentan características de peligrosidad: papel, cartón, plásticos, madera, metales, restos de embalaje, etc. Son residuos generados por industrias y comercios similares a los domésticos.' },
  { q: '¿Cada cuánto se recogen los residuos banales?', a: 'Ofrecemos recogidas periódicas adaptadas a tu volumen de generación: diaria, semanal, quincenal o mensual. También realizamos servicios puntuales.' },
  { q: '¿Ofrecéis contenedores?', a: 'Sí, proporcionamos contenedores de diferentes capacidades (120L, 240L, 800L, 1100L) en función de tus necesidades. El alquiler está incluido en el servicio de recogida periódica.' },
];
---

<Layout 
  title="Gestión de residuos banales en Barcelona"
  description="Gestión de residuos banales en Barcelona para empresas, industrias y comercios. Recogida periódica, contenedores incluidos y certificación. Presupuesto sin compromiso."
  canonical="https://ecociclo-niu.netlify.app/servicios/gestion-de-residuos-banales-en-barcelona"
>

<section class="bg-gradient-to-br from-[#36611C] to-[#00312D] text-white py-20">
  <div class="container-site">
    <h1 class="text-3xl md:text-5xl font-bold mb-4">Gestión de residuos banales en Barcelona</h1>
    <p class="text-lg text-gray-200 max-w-3xl">Servicio integral de recogida y gestión de residuos banales para empresas. Contenedores incluidos y recogida periódica adaptada a tus necesidades.</p>
  </div>
</section>

<section class="py-20 bg-white">
  <div class="container-site max-w-4xl">
    <div class="prose prose-lg max-w-none">
      <p class="text-gray-700 leading-relaxed text-lg mb-8">
        La <strong>gestión de residuos banales</strong> es una obligación legal para cualquier empresa, industria o comercio. En <strong>Ecociclo</strong> te ofrecemos un servicio completo que incluye la entrega de contenedores, recogida periódica y certificación de gestión.
      </p>
      
      <h2 class="text-2xl font-bold text-[#192a3d] mt-10 mb-4">Tipos de residuos banales que gestionamos</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 not-prose my-8">
        <div class="bg-[#EAFDE7] p-4 rounded-lg text-center"><span class="text-3xl">📄</span><p class="font-semibold text-sm mt-2">Papel y cartón</p></div>
        <div class="bg-[#EAFDE7] p-4 rounded-lg text-center"><span class="text-3xl">🧴</span><p class="font-semibold text-sm mt-2">Plásticos</p></div>
        <div class="bg-[#EAFDE7] p-4 rounded-lg text-center"><span class="text-3xl">🪵</span><p class="font-semibold text-sm mt-2">Madera</p></div>
        <div class="bg-[#EAFDE7] p-4 rounded-lg text-center"><span class="text-3xl">🔩</span><p class="font-semibold text-sm mt-2">Metales</p></div>
        <div class="bg-[#EAFDE7] p-4 rounded-lg text-center"><span class="text-3xl">📦</span><p class="font-semibold text-sm mt-2">Embalajes</p></div>
        <div class="bg-[#EAFDE7] p-4 rounded-lg text-center"><span class="text-3xl">🥤</span><p class="font-semibold text-sm mt-2">Envases</p></div>
      </div>
      
      <h2 class="text-2xl font-bold text-[#192a3d] mt-10 mb-4">Ventajas de nuestro servicio</h2>
      <ul class="space-y-2 text-gray-700">
        <li>🗑️ <strong>Contenedores incluidos</strong>: te proporcionamos los contenedores que necesites sin coste adicional</li>
        <li>📅 <strong>Recogida programada</strong>: nos adaptamos a tu ritmo de generación de residuos</li>
        <li>📋 <strong>Documentación legal</strong>: certificados de gestión para cumplir con la normativa</li>
        <li>♻️ <strong>Reciclaje garantizado</strong>: separamos y reciclamos al máximo todos los residuos</li>
        <li>💶 <strong>Tarifas competitivas</strong>: precios ajustados al volumen real de residuos</li>
      </ul>
    </div>
    
    <h2 class="text-2xl font-bold text-[#192a3d] mt-12 mb-6">Preguntas frecuentes</h2>
    <div class="space-y-4">
      {faqs.map((faq) => (
        <div class="border border-gray-200 rounded-lg overflow-hidden">
          <details class="group">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer hover:bg-[#EAFDE7] transition-colors font-semibold text-[#192a3d]">{faq.q}<span class="text-[#65C132] text-xl group-open:rotate-180 transition-transform">▾</span></summary>
            <div class="px-6 py-4 bg-gray-50 text-gray-600 text-sm leading-relaxed border-t border-gray-100">{faq.a}</div>
          </details>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="py-16 bg-gradient-to-r from-[#36611C] to-[#45891E] text-white">
  <div class="container-site text-center">
    <h2 class="text-2xl md:text-3xl font-bold mb-4">¿Necesitas gestionar tus residuos banales?</h2>
    <p class="text-lg text-gray-100 mb-6">Te ofrecemos una solución a medida para tu empresa</p>
    <a href="/contacto" class="inline-block bg-white text-[#36611C] px-8 py-3 rounded-full font-bold hover:bg-[#EAFDE7] transition-colors">Solicitar presupuesto →</a>
  </div>
</section>

</Layout>

---
import Layout from '../../layouts/Layout.astro';

const faqs = [
  { q: '¿Qué residuos especiales líquidos transportáis?', a: 'Transportamos aceites usados, disolventes, líquidos de frenos, refrigerantes, pinturas líquidas, ácidos, bases, lejías, pesticidas y cualquier residuo líquido clasificado como peligroso según la normativa vigente.' },
  { q: '¿Cómo se realiza el trasvase de líquidos?', a: 'Utilizamos bombas y sistemas de extracción seguros, con cubetos de retención ante derrames. Todo el personal está formado y equipado con EPIs adecuados.' },
  { q: '¿Disponéis de bidones y contenedores para líquidos?', a: 'Sí, suministramos bidones homologados de diferentes capacidades (25L, 50L, 200L), GRGs (1000L) y depósitos específicos según el tipo de residuo líquido.' },
];
---

<Layout 
  title="Transporte de residuos especiales líquidos en Barcelona"
  description="Transporte de residuos especiales líquidos en Barcelona. Servicio autorizado ADR, trasvase seguro y documentación completa. Presupuesto sin compromiso."
  canonical="https://ecociclo-niu.netlify.app/servicios/transporte-de-residuos-especiales-liquidos-en-barcelona"
>

<section class="bg-gradient-to-br from-[#36611C] to-[#00312D] text-white py-20">
  <div class="container-site">
    <h1 class="text-3xl md:text-5xl font-bold mb-4">Transporte de residuos especiales líquidos en Barcelona</h1>
    <p class="text-lg text-gray-200 max-w-3xl">Transporte autorizado de residuos especiales líquidos. Trasvase seguro, vehículos ADR y máxima garantía medioambiental.</p>
  </div>
</section>

<section class="py-20 bg-white">
  <div class="container-site max-w-4xl">
    <div class="prose prose-lg max-w-none">
      <p class="text-gray-700 leading-relaxed text-lg mb-8">
        El <strong>transporte de residuos especiales líquidos</strong> es una de las operaciones más delicadas en la gestión de residuos. En <strong>Ecociclo</strong> contamos con los equipos y la experiencia necesarios para garantizar un servicio 100% seguro.
      </p>
      
      <h2 class="text-2xl font-bold text-[#192a3d] mt-10 mb-4">Tipos de residuos líquidos que gestionamos</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 not-prose my-8">
        <div class="bg-[#EAFDE7] p-4 rounded-lg text-center"><span class="text-3xl">🛢️</span><p class="font-semibold text-sm mt-2">Aceites usados</p></div>
        <div class="bg-[#EAFDE7] p-4 rounded-lg text-center"><span class="text-3xl">🧪</span><p class="font-semibold text-sm mt-2">Disolventes</p></div>
        <div class="bg-[#EAFDE7] p-4 rounded-lg text-center"><span class="text-3xl">🧴</span><p class="font-semibold text-sm mt-2">Pinturas líquidas</p></div>
        <div class="bg-[#EAFDE7] p-4 rounded-lg text-center"><span class="text-3xl">⚗️</span><p class="font-semibold text-sm mt-2">Ácidos y bases</p></div>
        <div class="bg-[#EAFDE7] p-4 rounded-lg text-center"><span class="text-3xl">🚗</span><p class="font-semibold text-sm mt-2">Refrigerantes</p></div>
        <div class="bg-[#EAFDE7] p-4 rounded-lg text-center"><span class="text-3xl">💧</span><p class="font-semibold text-sm mt-2">Líquidos de frenos</p></div>
        <div class="bg-[#EAFDE7] p-4 rounded-lg text-center"><span class="text-3xl">🧹</span><p class="font-semibold text-sm mt-2">Lejías y detergentes</p></div>
        <div class="bg-[#EAFDE7] p-4 rounded-lg text-center"><span class="text-3xl">🌿</span><p class="font-semibold text-sm mt-2">Pesticidas</p></div>
      </div>
      
      <h2 class="text-2xl font-bold text-[#192a3d] mt-10 mb-4">Nuestro compromiso de seguridad</h2>
      <ul class="space-y-2 text-gray-700">
        <li>🛡️ <strong>Sistemas de contención</strong> de derrames en todos los vehículos</li>
        <li>🧤 <strong>EPIs específicos</strong> para manipulación de residuos líquidos peligrosos</li>
        <li>📦 <strong>Bidones homologados</strong> y etiquetados según normativa CLP</li>
        <li>📋 <strong>Documentación ADR</strong> completa para cada transporte</li>
        <li>🚨 <strong>Protocolo de emergencia</strong> ante derrames o incidentes</li>
      </ul>
    </div>
    
    <h2 class="text-2xl font-bold text-[#192a3d] mt-12 mb-6">Preguntas frecuentes</h2>
    <div class="space-y-4">
      {faqs.map((faq) => (
        <div class="border border-gray-200 rounded-lg overflow-hidden">
          <details class="group">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer hover:bg-[#EAFDE7] transition-colors font-semibold text-[#192a3d]">{faq.q}<span class="text-[#65C132] text-xl group-open:rotate-180 transition-transform">▾</span></summary>
            <div class="px-6 py-4 bg-gray-50 text-gray-600 text-sm leading-relaxed border-t border-gray-100">{faq.a}</div>
          </details>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="py-16 bg-gradient-to-r from-[#36611C] to-[#45891E] text-white">
  <div class="container-site text-center">
    <h2 class="text-2xl md:text-3xl font-bold mb-4">¿Necesitas gestionar residuos líquidos peligrosos?</h2>
    <p class="text-lg text-gray-100 mb-6">Contacta con nosotros y te asesoraremos sin compromiso</p>
    <a href="/contacto" class="inline-block bg-white text-[#36611C] px-8 py-3 rounded-full font-bold hover:bg-[#EAFDE7] transition-colors">Solicitar presupuesto →</a>
  </div>
</section>

</Layout>

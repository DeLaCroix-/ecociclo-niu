---
import Layout from '../../layouts/Layout.astro';

const faqs = [
  { q: '¿Qué incluye el servicio de vaciado?', a: 'Incluye la retirada de todos los objetos, muebles, residuos y escombros del espacio, carga en camión, transporte a gestor autorizado y certificación de gestión.' },
  { q: '¿Cuánto tiempo se tarda en vaciar una nave industrial?', a: 'Depende del tamaño y volumen. Una nave pequeña puede vaciarse en 1-2 días. Para naves grandes, elaboramos un plan de trabajo personalizado.' },
  { q: '¿Gestionáis la documentación?', a: 'Sí, proporcionamos toda la documentación legal necesaria: certificados de gestión de residuos, cartas de porte y justificantes de entrega a gestor autorizado.' },
];
---

<Layout 
  title="Vaciado de naves industriales, pisos y locales en Barcelona"
  description="Servicio profesional de vaciado de naves industriales, pisos y locales en Barcelona. Rápido, seguro y con certificación de gestión de residuos. Presupuesto sin compromiso."
  canonical="https://ecociclo-niu.netlify.app/servicios/vaciado-de-naves-industriales-pisos-y-locales-en-barcelona"
>

<!-- Hero -->
<section class="bg-gradient-to-br from-[#36611C] to-[#00312D] text-white py-20">
  <div class="container-site">
    <h1 class="text-3xl md:text-5xl font-bold mb-4">Vaciado de naves industriales, pisos y locales en Barcelona</h1>
    <p class="text-lg text-gray-200 max-w-3xl">Servicio integral de vaciado para cualquier tipo de espacio. Rápido, profesional y con todas las garantías.</p>
  </div>
</section>

<!-- Content -->
<section class="py-20 bg-white">
  <div class="container-site max-w-4xl">
    <div class="prose prose-lg max-w-none">
      <p class="text-gray-700 leading-relaxed text-lg mb-8">
        En <strong>Ecociclo</strong> somos especialistas en el <strong>vaciado de naves industriales, pisos y locales en Barcelona</strong>. Ofrecemos un servicio completo que incluye la retirada de mobiliario, maquinaria, residuos, escombros y cualquier elemento que necesites eliminar de tu espacio.
      </p>
      
      <h2 class="text-2xl font-bold text-[#192a3d] mt-10 mb-4">¿Por qué elegirnos para tu vaciado?</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 not-prose my-8">
        <div class="bg-[#EAFDE7] p-5 rounded-lg">
          <h4 class="font-bold text-[#36611C] mb-2">🚚 Recogida integral</h4>
          <p class="text-sm text-gray-700">Nos llevamos todo: muebles, maquinaria, residuos, escombros. Tú no tienes que preocuparte de nada.</p>
        </div>
        <div class="bg-[#EAFDE7] p-5 rounded-lg">
          <h4 class="font-bold text-[#36611C] mb-2">⚡ Rapidez garantizada</h4>
          <p class="text-sm text-gray-700">Servicio rápido. La mayoría de vaciados se completan en 24-48 horas.</p>
        </div>
        <div class="bg-[#EAFDE7] p-5 rounded-lg">
          <h4 class="font-bold text-[#36611C] mb-2">📋 Certificación incluida</h4>
          <p class="text-sm text-gray-700">Entregamos toda la documentación legal de gestión de residuos.</p>
        </div>
        <div class="bg-[#EAFDE7] p-5 rounded-lg">
          <h4 class="font-bold text-[#36611C] mb-2">💰 Presupuesto cerrado</h4>
          <p class="text-sm text-gray-700">Sin sorpresas. Te damos un precio cerrado tras evaluar tu espacio.</p>
        </div>
      </div>
      
      <h2 class="text-2xl font-bold text-[#192a3d] mt-10 mb-4">Tipos de vaciados que realizamos</h2>
      <ul class="space-y-2 text-gray-700">
        <li>✅ Vaciado de naves industriales</li>
        <li>✅ Vaciado de pisos y viviendas</li>
        <li>✅ Vaciado de locales comerciales</li>
        <li>✅ Vaciado de oficinas</li>
        <li>✅ Vaciado de trasteros y garajes</li>
        <li>✅ Vaciado de restaurantes y bares</li>
      </ul>
    </div>
    
    <!-- FAQ -->
    <h2 class="text-2xl font-bold text-[#192a3d] mt-12 mb-6">Preguntas frecuentes sobre vaciados</h2>
    <div class="space-y-4">
      {faqs.map((faq) => (
        <div class="border border-gray-200 rounded-lg overflow-hidden">
          <details class="group">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer hover:bg-[#EAFDE7] transition-colors font-semibold text-[#192a3d]">
              {faq.q}
              <span class="text-[#65C132] text-xl group-open:rotate-180 transition-transform">▾</span>
            </summary>
            <div class="px-6 py-4 bg-gray-50 text-gray-600 text-sm leading-relaxed border-t border-gray-100">{faq.a}</div>
          </details>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-16 bg-gradient-to-r from-[#36611C] to-[#45891E] text-white">
  <div class="container-site text-center">
    <h2 class="text-2xl md:text-3xl font-bold mb-4">¿Necesitas vaciar un espacio?</h2>
    <p class="text-lg text-gray-100 mb-6">Solicita tu presupuesto gratuito sin compromiso</p>
    <a href="/contacto" class="inline-block bg-white text-[#36611C] px-8 py-3 rounded-full font-bold hover:bg-[#EAFDE7] transition-colors">Solicitar presupuesto →</a>
  </div>
</section>

</Layout>

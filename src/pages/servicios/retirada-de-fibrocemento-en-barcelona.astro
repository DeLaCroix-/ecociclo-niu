---
import Layout from '../../layouts/Layout.astro';

const faqs = [
  { q: '¿Por qué es peligroso el fibrocemento?', a: 'El fibrocemento contiene amianto (asbesto), un material clasificado como cancerígeno de categoría 1 por la OMS. Cuando el fibrocemento se deteriora o manipula incorrectamente, libera fibras microscópicas de amianto que, al ser inhaladas, pueden causar graves enfermedades respiratorias.' },
  { q: '¿Qué normativa regula la retirada de fibrocemento?', a: 'La retirada está regulada por el RD 396/2006 y requiere que la empresa esté inscrita en el RERA (Registro de Empresas con Riesgo de Amianto). Ecociclo cumple con todos los requisitos legales.' },
  { q: '¿Cuánto cuesta retirar fibrocemento?', a: 'El coste depende de la cantidad, ubicación y accesibilidad. Realizamos una visita de evaluación sin compromiso para proporcionar un presupuesto detallado y cerrado.' },
  { q: '¿Puedo retirar el fibrocemento yo mismo?', a: 'No se recomienda bajo ningún concepto. La manipulación de amianto sin la protección y formación adecuadas es extremadamente peligrosa. Es obligatorio contratar una empresa autorizada como Ecociclo.' },
];
---

<Layout 
  title="Retirada de fibrocemento en Barcelona"
  description="Retirada de fibrocemento y desamiantado en Barcelona. Empresa autorizada RERA, máxima seguridad y cumplimiento del RD 396/2006. Presupuesto sin compromiso."
  canonical="https://ecociclo-niu.netlify.app/servicios/retirada-de-fibrocemento-en-barcelona"
>

<section class="bg-gradient-to-br from-[#36611C] to-[#00312D] text-white py-20">
  <div class="container-site">
    <h1 class="text-3xl md:text-5xl font-bold mb-4">Retirada de fibrocemento en Barcelona</h1>
    <p class="text-lg text-gray-200 max-w-3xl">Servicio profesional de retirada de fibrocemento y desamiantado. Empresa autorizada RERA con todas las garantías de seguridad.</p>
  </div>
</section>

<section class="py-20 bg-white">
  <div class="container-site max-w-4xl">
    <div class="prose prose-lg max-w-none">
      <p class="text-gray-700 leading-relaxed text-lg mb-8">
        La <strong>retirada de fibrocemento</strong> (desamiantado) es una operación crítica que solo puede ser realizada por empresas autorizadas. En <strong>Ecociclo</strong> estamos inscritos en el <strong>RERA</strong> y cumplimos estrictamente el <strong>RD 396/2006</strong> para garantizar la máxima seguridad.
      </p>
      
      <div class="bg-red-50 border-l-4 border-red-500 p-6 rounded-r-lg my-8 not-prose">
        <h3 class="font-bold text-red-800 text-lg mb-2">⚠️ El amianto es cancerígeno</h3>
        <p class="text-red-700 text-sm">No intentes manipular fibrocemento por tu cuenta. La inhalación de fibras de amianto puede causar asbestosis, cáncer de pulmón y mesotelioma. Solo empresas autorizadas pueden retirarlo.</p>
      </div>
      
      <h2 class="text-2xl font-bold text-[#192a3d] mt-10 mb-4">Nuestro protocolo de desamiantado</h2>
      <div class="space-y-4 not-prose">
        <div class="flex gap-4 items-start">
          <div class="w-10 h-10 bg-[#36611C] text-white rounded-full flex items-center justify-center font-bold flex-shrink-0">1</div>
          <div><h4 class="font-bold text-[#192a3d]">Evaluación y plan de trabajo</h4><p class="text-gray-600 text-sm">Inspección inicial, medición de amianto y presentación del plan de trabajo ante la autoridad laboral.</p></div>
        </div>
        <div class="flex gap-4 items-start">
          <div class="w-10 h-10 bg-[#45891E] text-white rounded-full flex items-center justify-center font-bold flex-shrink-0">2</div>
          <div><h4 class="font-bold text-[#192a3d]">Confinamiento y protección</h4><p class="text-gray-600 text-sm">Sellado de la zona y equipos de protección individual para nuestros trabajadores (EPIs con filtros HEPA).</p></div>
        </div>
        <div class="flex gap-4 items-start">
          <div class="w-10 h-10 bg-[#65C132] text-white rounded-full flex items-center justify-center font-bold flex-shrink-0">3</div>
          <div><h4 class="font-bold text-[#192a3d]">Retirada controlada</h4><p class="text-gray-600 text-sm">Desmontaje y encapsulado del fibrocemento. Embalaje en sacas estancas homologadas para transporte.</p></div>
        </div>
        <div class="flex gap-4 items-start">
          <div class="w-10 h-10 bg-[#00312D] text-white rounded-full flex items-center justify-center font-bold flex-shrink-0">4</div>
          <div><h4 class="font-bold text-[#192a3d]">Transporte y certificación</h4><p class="text-gray-600 text-sm">Transporte a gestor autorizado y entrega de certificado de retirada y gestión de residuos con amianto.</p></div>
        </div>
      </div>
      
      <h2 class="text-2xl font-bold text-[#192a3d] mt-10 mb-4">Dónde se encuentra el fibrocemento</h2>
      <div class="grid grid-cols-2 gap-3 not-prose my-6">
        <span class="bg-gray-100 px-4 py-2 rounded-lg text-sm">Cubiertas y tejados</span>
        <span class="bg-gray-100 px-4 py-2 rounded-lg text-sm">Bajantes y canalones</span>
        <span class="bg-gray-100 px-4 py-2 rounded-lg text-sm">Depósitos de agua</span>
        <span class="bg-gray-100 px-4 py-2 rounded-lg text-sm">Jardineras</span>
        <span class="bg-gray-100 px-4 py-2 rounded-lg text-sm">Conductos de ventilación</span>
        <span class="bg-gray-100 px-4 py-2 rounded-lg text-sm">Paneles divisorios</span>
      </div>
    </div>
    
    <h2 class="text-2xl font-bold text-[#192a3d] mt-12 mb-6">Preguntas frecuentes</h2>
    <div class="space-y-4">
      {faqs.map((faq) => (
        <div class="border border-gray-200 rounded-lg overflow-hidden">
          <details class="group">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer hover:bg-[#EAFDE7] transition-colors font-semibold text-[#192a3d]">{faq.q}<span class="text-[#65C132] text-xl group-open:rotate-180 transition-transform">▾</span></summary>
            <div class="px-6 py-4 bg-gray-50 text-gray-600 text-sm leading-relaxed border-t border-gray-100">{faq.a}</div>
          </details>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="py-16 bg-gradient-to-r from-[#36611C] to-[#45891E] text-white">
  <div class="container-site text-center">
    <h2 class="text-2xl md:text-3xl font-bold mb-4">¿Tienes fibrocemento que retirar?</h2>
    <p class="text-lg text-gray-100 mb-6">No te arriesgues. Solicita presupuesto a una empresa autorizada.</p>
    <a href="/contacto" class="inline-block bg-white text-[#36611C] px-8 py-3 rounded-full font-bold hover:bg-[#EAFDE7] transition-colors">Solicitar presupuesto →</a>
  </div>
</section>

</Layout>

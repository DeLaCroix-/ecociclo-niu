---
import Layout from '../../layouts/Layout.astro';

const faqs = [
  { q: '¿Qué incluye la limpieza de terrenos?', a: 'Incluye desbroce de vegetación, retirada de residuos y escombros, tala controlada de árboles si es necesario, limpieza general y transporte de todos los residuos a gestor autorizado.' },
  { q: '¿Limpiáis terrenos de cualquier tamaño?', a: 'Sí, trabajamos en parcelas de cualquier dimensión, desde pequeños solares urbanos hasta grandes fincas rústicas. Adaptamos los equipos al tamaño del terreno.' },
  { q: '¿Necesito permisos para limpiar mi terreno?', a: 'En general, no se requieren permisos especiales para la limpieza y desbroce. Si hay árboles protegidos o el terreno está en zona especial, te asesoramos sobre los trámites necesarios.' },
  { q: '¿Qué hacéis con los residuos vegetales?', a: 'Los residuos vegetales se transportan a plantas de compostaje o valorización energética. Priorizamos las opciones más sostenibles de gestión.' },
];
---

<Layout 
  title="Limpieza de terrenos y parcelas en Barcelona"
  description="Limpieza de terrenos y parcelas en Barcelona. Desbroce, retirada de residuos y acondicionamiento de espacios exteriores. Presupuesto sin compromiso."
  canonical="https://ecociclo-niu.netlify.app/servicios/limpieza-de-terrenos-y-parcelas-en-barcelona"
>

<section class="bg-gradient-to-br from-[#36611C] to-[#00312D] text-white py-20">
  <div class="container-site">
    <h1 class="text-3xl md:text-5xl font-bold mb-4">Limpieza de terrenos y parcelas en Barcelona</h1>
    <p class="text-lg text-gray-200 max-w-3xl">Servicio integral de limpieza, desbroce y acondicionamiento de terrenos. Recupera tu espacio exterior de forma rápida y profesional.</p>
  </div>
</section>

<section class="py-20 bg-white">
  <div class="container-site max-w-4xl">
    <div class="prose prose-lg max-w-none">
      <p class="text-gray-700 leading-relaxed text-lg mb-8">
        La <strong>limpieza de terrenos y parcelas</strong> es esencial para mantener la seguridad, evitar incendios y poner en valor tus espacios exteriores. En <strong>Ecociclo</strong> realizamos limpiezas integrales de cualquier tipo de terreno.
      </p>
      
      <h2 class="text-2xl font-bold text-[#192a3d] mt-10 mb-4">Servicios incluidos</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 not-prose my-8">
        <div class="bg-[#EAFDE7] p-5 rounded-lg"><h4 class="font-bold text-[#36611C] mb-2">🌿 Desbroce</h4><p class="text-sm text-gray-700">Eliminación de maleza, hierbas y vegetación no deseada con equipos mecánicos y manuales.</p></div>
        <div class="bg-[#EAFDE7] p-5 rounded-lg"><h4 class="font-bold text-[#36611C] mb-2">🪓 Tala controlada</h4><p class="text-sm text-gray-700">Tala de árboles muertos o peligrosos con todas las medidas de seguridad.</p></div>
        <div class="bg-[#EAFDE7] p-5 rounded-lg"><h4 class="font-bold text-[#36611C] mb-2">🗑️ Retirada de residuos</h4><p class="text-sm text-gray-700">Recogida de escombros, basura y cualquier tipo de residuo acumulado en el terreno.</p></div>
        <div class="bg-[#EAFDE7] p-5 rounded-lg"><h4 class="font-bold text-[#36611C] mb-2">🚛 Transporte y gestión</h4><p class="text-sm text-gray-700">Carga y transporte de todos los residuos a gestores autorizados con certificación.</p></div>
      </div>
      
      <h2 class="text-2xl font-bold text-[#192a3d] mt-10 mb-4">Tipos de terrenos que limpiamos</h2>
      <ul class="space-y-2 text-gray-700">
        <li>🏡 Solares urbanos</li>
        <li>🏭 Parcelas industriales</li>
        <li>🌳 Fincas rústicas</li>
        <li>🏗️ Terrenos en construcción</li>
        <li>🏘️ Parcelas residenciales</li>
        <li>🅿️ Descampados y aparcamientos</li>
      </ul>
      
      <h2 class="text-2xl font-bold text-[#192a3d] mt-10 mb-4">Beneficios de mantener tu terreno limpio</h2>
      <ul class="space-y-2 text-gray-700">
        <li>🔥 <strong>Prevención de incendios</strong>: eliminar la maleza seca reduce drásticamente el riesgo</li>
        <li>🦟 <strong>Control de plagas</strong>: evita la proliferación de insectos y roedores</li>
        <li>💶 <strong>Revalorización</strong>: un terreno limpio y cuidado aumenta su valor de mercado</li>
        <li>📋 <strong>Cumplimiento legal</strong>: evita sanciones municipales por falta de mantenimiento</li>
      </ul>
    </div>
    
    <h2 class="text-2xl font-bold text-[#192a3d] mt-12 mb-6">Preguntas frecuentes</h2>
    <div class="space-y-4">
      {faqs.map((faq) => (
        <div class="border border-gray-200 rounded-lg overflow-hidden">
          <details class="group">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer hover:bg-[#EAFDE7] transition-colors font-semibold text-[#192a3d]">{faq.q}<span class="text-[#65C132] text-xl group-open:rotate-180 transition-transform">▾</span></summary>
            <div class="px-6 py-4 bg-gray-50 text-gray-600 text-sm leading-relaxed border-t border-gray-100">{faq.a}</div>
          </details>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="py-16 bg-gradient-to-r from-[#36611C] to-[#45891E] text-white">
  <div class="container-site text-center">
    <h2 class="text-2xl md:text-3xl font-bold mb-4">¿Necesitas limpiar tu terreno?</h2>
    <p class="text-lg text-gray-100 mb-6">Solicita tu presupuesto gratuito sin compromiso</p>
    <a href="/contacto" class="inline-block bg-white text-[#36611C] px-8 py-3 rounded-full font-bold hover:bg-[#EAFDE7] transition-colors">Solicitar presupuesto →</a>
  </div>
</section>

</Layout>

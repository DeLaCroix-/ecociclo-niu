---
import Layout from '../layouts/Layout.astro';

const services = [
  { title: 'VACIADOS Y LIMPIEZA', desc: 'Vaciado de naves industriales, pisos, trasteros, locales y oficinas. Servicio rápido y profesional con toda la documentación legal.', href: '/servicios/vaciado-de-naves-industriales-pisos-y-locales-en-barcelona', icon: '🏭' },
  { title: 'GESTIÓN DE RESIDUOS BANALES', desc: 'Contenedores para la gestión de residuos industriales. Recogida, transporte y gestión documentada de residuos no peligrosos.', href: '/servicios/gestion-de-residuos-banales-en-barcelona', icon: '🗑️' },
  { title: 'RESIDUOS ESPECIALES LÍQUIDOS', desc: 'Gestión y transporte de residuos especiales líquidos con todas las garantías de seguridad y cumplimiento de la normativa ADR.', href: '/servicios/transporte-de-residuos-especiales-liquidos-en-barcelona', icon: '🧪' },
  { title: 'RESIDUOS ESPECIALES SÓLIDOS', desc: 'Gestión y transporte de residuos especiales sólidos. Manipulación segura y documentación legal completa.', href: '/servicios/transporte-de-residuos-especiales-solidos-en-barcelona', icon: '⚠️' },
  { title: 'RETIRADA DE FIBROCEMENTO', desc: 'Servicio profesional de retirada de fibrocemento y uralita en Barcelona. Desamiantado seguro con todas las garantías.', href: '/servicios/retirada-de-fibrocemento-en-barcelona', icon: '🧱' },
  { title: 'LIMPIEZA DE TERRENOS', desc: 'Servicio de limpieza y desbroce de terrenos y parcelas. Acondicionamiento de espacios exteriores.', href: '/servicios/limpieza-de-terrenos-y-parcelas-en-barcelona', icon: '🌿' },
  { title: 'LIMPIEZA DE SÍNDROME DE DIÓGENES', desc: 'Limpieza de lugares afectados por el síndrome de Diógenes. Tratamiento especializado con máxima discreción y profesionalidad.', href: '/servicios/limpieza-de-diogenes-en-barcelona', icon: '🏠' },
  { title: 'TRASVASES Y ACONDICIONAMIENTO', desc: 'Realizamos el trasvase de residuos peligrosos y no peligrosos. Manipulación, envasado y etiquetado según normativa.', href: '/servicios/acondicionamiento-de-residuos-peligrosos-en-barcelona', icon: '🔄' },
];
---

<Layout 
  title="Servicios de Gestión Ambiental"
  description="Servicios de gestión ambiental en Barcelona: vaciado de naves, limpieza de Diógenes, retirada de fibrocemento, gestión de residuos especiales y más."
  canonical="https://ecociclonew.netlify.app/servicios-de-gestion-ambiental"
>

<!-- Page Header -->
<section class="bg-[#192a3d] text-white py-16 md:py-20">
  <div class="container-site px-4 text-center">
    <h1 class="text-3xl md:text-5xl font-bold mb-4">Servicios de Gestión Ambiental en barcelona</h1>
  </div>
</section>

<!-- Services List -->
<section class="py-20 bg-white">
  <div class="container-site px-4">
    <h2 class="text-3xl md:text-4xl font-bold text-[#192a3d] text-center mb-14">Servicios de Gestión Ambiental para tu empresa</h2>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-6xl mx-auto">
      {services.map((s) => (
        <a href={s.href} class="group bg-white rounded-xl p-6 border border-gray-100 shadow-sm hover:shadow-lg hover:border-[#65C132] transition-all duration-300 flex flex-col">
          <span class="text-4xl mb-4">{s.icon}</span>
          <h3 class="font-bold text-[#192a3d] text-sm mb-3 group-hover:text-[#36611C] transition-colors">{s.title}</h3>
          <p class="text-gray-500 text-sm leading-relaxed flex-1">{s.desc}</p>
          <span class="inline-flex items-center gap-1 text-[#65C132] text-sm font-medium mt-4 group-hover:gap-2 transition-all">
            Ver Servicio →
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- Stats -->
<section class="py-20 bg-[#192a3d] text-white">
  <div class="container-site px-4 text-center">
    <h2 class="text-3xl md:text-4xl font-bold mb-4">Líderes en gestión de residuos en Barcelona</h2>
    <p class="text-gray-300 text-lg max-w-2xl mx-auto mb-14">Más de una década ofreciendo soluciones de gestión de residuos para empresas, industria y locales en toda Cataluña.</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 max-w-4xl mx-auto">
      <div>
        <div class="text-5xl font-bold text-[#65C132] mb-2">+2.500</div>
        <p class="text-gray-300">Servicios realizados</p>
      </div>
      <div>
        <div class="text-5xl font-bold text-[#65C132] mb-2">+10</div>
        <p class="text-gray-300">Años de experiencia</p>
      </div>
      <div>
        <div class="text-5xl font-bold text-[#65C132] mb-2">24/48h</div>
        <p class="text-gray-300">Respuesta rápida</p>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-16 bg-gradient-to-r from-[#36611C] to-[#45891E] text-white text-center">
  <div class="container-site px-4">
    <h2 class="text-3xl font-bold mb-4">¿Necesitas una solución para tu gestión de residuos?</h2>
    <p class="text-gray-100 mb-8 text-lg">Solicita tu presupuesto sin compromiso y te responderemos en menos de 24 horas.</p>
    <a href="/contacto" class="inline-block bg-white text-[#36611C] px-10 py-4 rounded-full font-bold text-lg hover:bg-[#EAFDE7] transition-all">Solicitar presupuesto →</a>
  </div>
</section>

</Layout>

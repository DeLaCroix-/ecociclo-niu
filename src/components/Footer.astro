---
// Footer.astro — Rebuilt from ecociclo.es footer (Blocksy theme type-1)
// Images: /public/images/23-1.webp (background), /public/images/Ecociclo-Logo-Horizontal3-scaled.png (logo)
---

<footer id="footer" class="ct-footer" data-id="type-1" itemscope itemtype="https://schema.org/WPFooter">
  <!-- ===== MIDDLE ROW: 4 columns ===== -->
  <div data-row="middle">
    <div class="ct-container" data-columns-divider="md:sm">
      
      <!-- COLUMN 1: Logo + Description (2fr) -->
      <div data-column="widget-area-1">
        <div class="ct-widget widget_block" id="block-19">
          <div class="footer-col footer-col-logo">
            <div class="footer-logo-wrap">
              <img
                loading="lazy"
                decoding="async"
                src="/images/Ecociclo-Logo-Horizontal3-scaled.png"
                alt="Ecociclo"
                width="250"
                height="61"
              />
            </div>
            <p class="footer-desc">
              En&nbsp;<strong>ECOCICLO</strong>&nbsp;ofrecemos un servicio profesional de limpieza y desalojo de naves industriales, locales, oficinas y pisos.
            </p>
          </div>
        </div>
      </div>

      <!-- COLUMN 2: Enlaces directos (1fr) -->
      <div data-column="widget-area-3">
        <div class="ct-widget widget_block" id="block-18">
          <div class="footer-col">
            <h5 class="footer-heading">Enlaces directos</h5>
            <ul class="footer-links">
              <li><a href="/">Inicio</a></li>
              <li><a href="/empresa-de-gestion-de-residuos">Quiénes somos</a></li>
              <li><a href="/servicios-de-gestion-ambiental">Servicios</a></li>
              <li><a href="/blog">Blog</a></li>
            </ul>
          </div>
        </div>
      </div>

      <!-- COLUMN 3: Soporte (1fr) -->
      <div data-column="widget-area-2">
        <div class="ct-widget widget_block" id="block-17">
          <div class="footer-col">
            <h5 class="footer-heading">Soporte</h5>
            <ul class="footer-links">
              <li><a href="/faqs">FAQs</a></li>
              <li><a href="/noticias">Noticias</a></li>
              <li><a href="/contacto">Contacto</a></li>
              <li><a href="/politica-privacidad">Políticas de privacidad</a></li>
            </ul>
          </div>
        </div>
      </div>

      <!-- COLUMN 4: Horarios / Contacto (1fr) -->
      <div data-column="widget-area-5">
        <div class="ct-widget widget_block" id="block-21">
          <div class="footer-col">
            <h5 class="footer-heading">Horarios</h5>
            <p class="footer-schedule"><strong>Lunes a Viernes</strong></p>
            <p class="footer-schedule">De 8:30h a 13:30h</p>
            <p class="footer-schedule">De 15:00h a 18:00h</p>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- ===== BOTTOM ROW: Copyright + Socials ===== -->
  <div data-row="bottom">
    <div class="ct-container ct-container-bottom">
      <!-- Copyright -->
      <div data-column="copyright">
        <div class="ct-footer-copyright" data-id="copyright">
          <p>Copyright &copy; 2026 - Ecociclo</p>
        </div>
      </div>

      <!-- Social Icons -->
      <div data-column="socials">
        <div class="ct-footer-socials" data-id="socials">
          <div class="ct-social-box" data-color="custom" data-icon-size="custom" data-icons-type="rounded:solid">
            <a href="#" data-network="facebook" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
              <span class="ct-icon-container">
                <svg width="20px" height="20px" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M20,10.1c0-5.5-4.5-10-10-10S0,4.5,0,10.1c0,5,3.7,9.1,8.4,9.9v-7H5.9v-2.9h2.5V7.9C8.4,5.4,9.9,4,12.2,4c1.1,0,2.2,0.2,2.2,0.2v2.5h-1.3c-1.2,0-1.6,0.8-1.6,1.6v1.9h2.8L13.9,13h-2.3v7C16.3,19.2,20,15.1,20,10.1z"/>
                </svg>
              </span>
            </a>
            <a href="#" data-network="twitter" aria-label="X (Twitter)" target="_blank" rel="noopener noreferrer">
              <span class="ct-icon-container">
                <svg width="20px" height="20px" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M2.9 0C1.3 0 0 1.3 0 2.9v14.3C0 18.7 1.3 20 2.9 20h14.3c1.6 0 2.9-1.3 2.9-2.9V2.9C20 1.3 18.7 0 17.1 0H2.9zm13.2 3.8L11.5 9l5.5 7.2h-4.3l-3.3-4.4-3.8 4.4H3.4l5-5.7-5.3-6.7h4.4l3 4 3.5-4h2.1zM14.4 15 6.8 5H5.6l7.7 10h1.1z"/>
                </svg>
              </span>
            </a>
            <a href="#" data-network="instagram" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
              <span class="ct-icon-container">
                <svg width="20" height="20" viewBox="0 0 20 20" aria-hidden="true">
                  <circle cx="10" cy="10" r="3.3"/>
                  <path d="M14.2,0H5.8C2.6,0,0,2.6,0,5.8v8.3C0,17.4,2.6,20,5.8,20h8.3c3.2,0,5.8-2.6,5.8-5.8V5.8C20,2.6,17.4,0,14.2,0zM10,15c-2.8,0-5-2.2-5-5s2.2-5,5-5s5,2.2,5,5S12.8,15,10,15z M15.8,5C15.4,5,15,4.6,15,4.2s0.4-0.8,0.8-0.8s0.8,0.4,0.8,0.8S16.3,5,15.8,5z"/>
                </svg>
              </span>
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>
</footer>

<style>
  /* ===== FOOTER BASE ===== */
  .ct-footer {
    background-color: #f2f5f7;
    background-image:
      linear-gradient(rgba(54, 97, 28, 0.84), rgba(54, 97, 28, 0.84)),
      url('/images/23.webp');
    background-size: cover;
    background-position: 48% 49%;
    background-repeat: no-repeat;
    background-attachment: scroll;
    padding-top: 60px;
    display: block;
    position: relative;
    z-index: 1;
  }

  /* ===== DATA-ROW STRUCTURE ===== */
  .ct-footer [data-row] {
    display: block;
    width: 100%;
  }

  .ct-footer [data-row="middle"] {
    padding-bottom: 0;
  }

  .ct-footer [data-row="bottom"] {
    padding-top: 0;
  }

  /* ===== CONTAINER ===== */
  .ct-container {
    max-width: 1290px;
    margin: 0 auto;
    padding: 50px 35px;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 50px;
    border-bottom: 1px solid rgba(221, 221, 221, 0.3);
  }

  /* Bottom row container: 3fr 1fr */
  .ct-container-bottom {
    grid-template-columns: 3fr 1fr;
    padding: 25px 35px;
    border-bottom: none;
    align-items: center;
  }

  /* ===== COLUMNS ===== */
  [data-column] {
    display: flex;
    flex-direction: column;
  }

  /* ===== COL 1: LOGO + DESC ===== */
  .footer-col-logo {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    row-gap: 10px;
    padding-right: 70px;
  }

  .footer-logo-wrap {
    text-align: left;
  }

  .footer-logo-wrap img {
    width: 250px;
    height: auto;
    max-width: 100%;
    vertical-align: top;
    display: inline-block;
  }

  .footer-desc {
    color: #ffffff;
    margin: 0;
    font-size: 16px;
    font-weight: 400;
    line-height: 1.65;
    font-family: 'SoinSans', sans-serif;
  }

  .footer-desc strong {
    font-weight: 700;
  }

  /* ===== WIDGET COLUMNS (2, 3, 4) ===== */
  .footer-col {
    display: flex;
    flex-direction: column;
    row-gap: 15px;
  }

  .footer-heading {
    font-size: 20px;
    font-weight: 700;
    color: #ffffff;
    margin: 0;
    line-height: 1.65;
    font-family: 'SoinSans', sans-serif;
  }

  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    row-gap: 8px;
  }

  .footer-links a {
    color: #ffffff;
    text-decoration: none;
    font-size: 16px;
    font-weight: 400;
    line-height: 1.65;
    font-family: 'SoinSans', sans-serif;
    transition: color 0.12s cubic-bezier(0.455, 0.03, 0.515, 0.955);
  }

  .footer-links a:hover {
    color: #192a3d;
  }

  .footer-schedule {
    color: #ffffff;
    margin: 0;
    font-size: 16px;
    font-weight: 400;
    line-height: 1.65;
    font-family: 'SoinSans', sans-serif;
  }

  .footer-schedule strong {
    font-weight: 700;
  }

  /* ===== BOTTOM ROW ===== */
  [data-column="copyright"] {
    justify-content: flex-start;
  }

  .ct-footer-copyright p {
    color: #ffffff;
    font-size: 15px;
    font-weight: 400;
    margin: 0;
    line-height: 1.3;
    font-family: 'SoinSans', sans-serif;
  }

  [data-column="socials"] {
    align-items: flex-end;
  }

  .ct-footer-socials {
    display: block;
  }

  .ct-social-box {
    display: flex;
    justify-content: flex-end;
    flex-wrap: wrap;
    gap: 15px;
  }

  .ct-social-box a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 37.5px;
    height: 37.5px;
    color: #ffffff;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.15);
    border-radius: 100%;
    transition: background 0.12s cubic-bezier(0.455, 0.03, 0.515, 0.955);
  }

  .ct-social-box a:hover {
    background: rgba(255, 255, 255, 0.3);
  }

  .ct-icon-container {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ct-icon-container svg {
    fill: #ffffff;
    display: block;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 999.98px) {
    .ct-container {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
      padding: 40px 35px;
    }
    .ct-container-bottom {
      grid-template-columns: 1fr 1fr;
    }
    .footer-col-logo {
      padding-right: 0;
    }
  }

  @media (max-width: 689.98px) {
    .ct-container {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 40px 20px;
    }
    .ct-container-bottom {
      grid-template-columns: 1fr;
      gap: 20px;
      padding: 25px 20px;
      text-align: center;
    }
    [data-column="socials"] {
      align-items: center;
    }
    .ct-social-box {
      justify-content: center;
    }
    [data-column="copyright"] {
      align-items: center;
    }
    .footer-logo-wrap img {
      width: 200px;
    }
  }
</style>

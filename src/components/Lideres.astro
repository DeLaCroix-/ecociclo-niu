<style>
  /* ===== LÍDERES SECTION (exact: #gspb_row-id-gsbp-022f526, top:3139, h:847) ===== */
  .lideres-section {
    position: relative;
    overflow: hidden;
    padding-top: 70px;
    padding-bottom: 70px;
  }

  /* ===== DESKTOP-ONLY: hidden on mobile ===== */
  @media (max-width: 689.98px) {
    .lideres-section {
      display: none !important;
    }
  }

  /* ===== FLOATING DECORATIVE LEAVES ===== */
  .lideres-leaf {
    position: absolute;
    z-index: 0;
    pointer-events: none;
  }

  .lideres-leaf img {
    display: block;
    height: 150px;
    width: auto;
  }

  /* Leaf 1 — top:155px, left:50px, rotateZ(98deg) */
  .lideres-leaf--left {
    top: 155px;
    left: 50px;
  }

  .lideres-leaf--left img {
    transform: rotateZ(98deg);
    transition: all 0.5s cubic-bezier(0.42, 0, 0.58, 1);
  }

  /* Leaf 2 — top:160px, right:0, rotateZ(50deg), transform-origin: top right */
  .lideres-leaf--right {
    top: 160px;
    right: 0;
  }

  .lideres-leaf--right img {
    transform: rotateZ(50deg);
    transform-origin: top right;
    transition: all 0.5s cubic-bezier(0.42, 0, 0.58, 1);
  }

  /* ===== AOS ANIMATIONS (via IntersectionObserver) ===== */
  /* Hidden state — elements with [data-aos] start hidden */
  [data-aos] {
    transition-duration: 0.8s;
    transition-property: opacity, transform, filter;
    transition-timing-function: cubic-bezier(0.42, 0, 0.58, 1);
  }

  /* Fade-right: slide from left */
  [data-aos="fade-right"] {
    opacity: 0;
    transform: translate3d(calc(max(50px, 15%) * -1), 0, 0);
  }
  [data-aos="fade-right"].aos-animate {
    opacity: 1;
    transform: translateZ(0);
  }

  /* Fade-left: slide from right */
  [data-aos="fade-left"] {
    opacity: 0;
    transform: translate3d(calc(max(50px, 15%)), 0, 0);
  }
  [data-aos="fade-left"].aos-animate {
    opacity: 1;
    transform: translateZ(0);
  }

  /* Fade-down-right: slide from top-left */
  [data-aos="fade-down-right"] {
    opacity: 0;
    transform: translate3d(calc(max(50px, 15%) * -1), calc(max(50px, 15%) * -1), 0);
  }
  [data-aos="fade-down-right"].aos-animate {
    opacity: 1;
    transform: translateZ(0);
  }
  /* Leaf left keeps its rotation when animated */
  .lideres-leaf--left[data-aos="fade-down-right"] {
    transform: translate3d(calc(max(50px, 15%) * -1), calc(max(50px, 15%) * -1), 0);
  }
  .lideres-leaf--left[data-aos="fade-down-right"].aos-animate {
    opacity: 1;
    transform: translateZ(0);
  }

  /* Fade-up-left: slide from bottom-right */
  [data-aos="fade-up-left"] {
    opacity: 0;
    transform: translate3d(calc(max(50px, 15%)), calc(max(50px, 15%)), 0);
  }
  [data-aos="fade-up-left"].aos-animate {
    opacity: 1;
    transform: translateZ(0);
  }
  .lideres-leaf--right[data-aos="fade-up-left"] {
    transform: translate3d(calc(max(50px, 15%)), calc(max(50px, 15%)), 0);
  }
  .lideres-leaf--right[data-aos="fade-up-left"].aos-animate {
    opacity: 1;
    transform: translateZ(0);
  }

  /* Zoom-in: scale from 0.6 */
  [data-aos="zoom-in"] {
    opacity: 0;
    transform: scale(0.6);
    transition-timing-function: cubic-bezier(0.6, -0.28, 0.735, 0.045);
  }
  [data-aos="zoom-in"].aos-animate {
    opacity: 1;
    transform: scale(1);
  }

  /* Zoom-out: scale from 1.2 */
  [data-aos="zoom-out"] {
    opacity: 0;
    transform: scale(1.2);
    transition-timing-function: cubic-bezier(0.42, 0, 0.58, 1);
  }
  [data-aos="zoom-out"].aos-animate {
    opacity: 1;
    transform: scale(1);
  }

  /* Easing overrides via data-aos-easing */
  [data-aos-easing="ease"] {
    transition-timing-function: cubic-bezier(0.42, 0, 0.58, 1);
  }
  [data-aos-easing="ease-out-cubic"] {
    transition-timing-function: cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  [data-aos-easing="ease-in-back"] {
    transition-timing-function: cubic-bezier(0.6, -0.28, 0.735, 0.045);
  }
  [data-aos-easing="ease-in-out-back"] {
    transition-timing-function: cubic-bezier(0.68, -0.55, 0.265, 1.55);
  }

  /* Duration override */
  [data-aos-duration="800"] {
    transition-duration: 0.8s;
  }

  /* Icon box wrapper uses its own inline-flex display and zoom-in */
  .lideres-card__icon,
  .lideres-stat__icon {
    /* These host the zoom-in animation */
  }


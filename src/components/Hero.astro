<style>
  /* ================================================================
     HERO SECTION — Exact reproduction of ecociclo.es hero
     Greenshift block gspb_row-id-gsbp-87fe861
     Background: 23.webp, cover, 50% 49%
     Height: ~727px (flex with min-height)
  ================================================================ */

  .hero {
    position: relative;
    display: flex;
    align-items: normal;
    justify-content: space-between;
    flex-wrap: wrap;
    min-height: 727px;
    /* Computed styles from original */
    background-color: #888888;
    background-image: url('/images/23.webp');
    background-size: cover;
    background-position: 50% 49%;
    background-repeat: no-repeat;
    background-attachment: fixed;
    margin: 0;
    padding: 0;
    border: 0;
    overflow: visible;
  }

  /* Background overlay placeholder (original has gspb_backgroundOverlay but it's transparent) */
  .hero-overlay {
    display: none;
  }

  /* Inner wrapper — 12-col full-width, padding-top: 160px (accounts for header overlay) */
  .hero-inner {
    width: 100%;
    padding: 160px 20px 0;
    position: relative;
    box-sizing: border-box;
  }

  /* Flex row — matches gspb_row-id-gsbp-ef8b9d5 */
  .hero-row {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    margin: 0 auto;
    width: 100%;
    max-width: 1290px; /* computed: 1290px content area */
  }

  /* ---- COL 1: Text (33.33%) ---- */
  .hero-col {
    box-sizing: border-box;
    position: relative;
  }

  .hero-col-text {
    width: 33.333%;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: stretch;
    row-gap: 10px;
    padding: 70px 20px 15px;
  }

  /* H1 heading */
  .hero-heading {
    font-family: 'SoinSans', sans-serif;
    font-weight: 700;
    font-size: 38px;
    line-height: 1.5;      /* 57px / 38px */
    color: #ffffff;
    text-transform: uppercase;
    margin: 0 -150px 0 0;   /* negative right margin to extend text */
    padding: 0;
  }

  /* Description text */
  .hero-desc {
    font-family: 'SoinSans', sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 1.6;      /* 28.8px / 18px */
    color: #ffffff;
    margin: 0 -60px 0 0;   /* negative right margin */
    padding: 0;
  }

  .hero-desc strong {
    font-weight: 700;
  }

  /* CTA wrapper (padding-top: 15px on original container) */
  .hero-cta-wrap {
    padding-top: 15px;
  }

  /* CTA button */
  .hero-cta {
    display: inline-block;
    align-self: flex-start;
    background-color: #65C132;
    color: #ffffff;
    font-family: 'SoinSans', sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 1.6;
    text-decoration: none;
    padding: 10px 25px;
    border-radius: 15px;
    border: 0;
    box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.02);
    transition: background-color 0.25s, box-shadow 0.25s, transform 0.25s;
    transition-timing-function: cubic-bezier(0.42, 0, 0.58, 1);
  }

  .hero-cta strong {
    font-weight: 700;
  }

  .hero-cta:hover {
    background-color: #45891E;
    box-shadow: 0 8px 15px 0 rgba(0, 0, 0, 0.25);
    transform: translateY(-3px);
    color: #ffffff;
  }

  .hero-cta:active {
    box-shadow: 0 1px 0 0 rgba(0, 0, 0, 0.25);
    transform: translateY(3px);
  }

  /* ---- COL 2: Overlay Image (33.33%) ---- */
  .hero-col-image {
    width: 33.333%;
    display: flex;
    justify-content: center;
    align-items: flex-end;   /* bottom-aligned */
    padding: 0;
    margin: 0;
  }

  .hero-image-wrap {
    display: block;
  }

  .hero-overlay-img {
    display: inline-block;
    width: 320px;
    height: auto;
    max-width: 100%;
    vertical-align: top;
  }

  /* ---- COL 3: Feature Cards (33.33%) ---- */
  .hero-col-features {
    width: 33.333%;
    display: flex;
    flex-direction: column;
    justify-content: center;   /* vertically centered */
    align-items: flex-end;
    row-gap: 20px;
    padding: 15px 20px 15px 60px;   /* left padding 60px */
  }

  /* Feature card (container with light green bg, border-radius 10px) */
  .feature-card {
    background-color: #EAFDE7;
    border-radius: 10px;
    position: relative;
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: 350px;
    box-sizing: border-box;
  }

  .feature-row {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    width: 100%;
  }

  /* Icon column: 25% width */
  .feature-icon-col {
    width: 25%;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 15px 20px;
    box-sizing: border-box;
  }

  /* Icon box: green background, border-radius 5px */
  .feature-icon-box {
    background-color: #65C132;
    border-radius: 5px;
    padding: 8px;
    position: relative;
    display: block;
    box-sizing: border-box;
  }

  .feature-icon {
    display: flex;
    justify-content: center;
  }

  .feature-icon svg {
    width: 40px;
    height: 40px;
    min-width: 40px;
    display: block;
    fill: #ffffff;
  }

  .feature-icon svg path {
    fill: #ffffff;
  }

  /* Text column: 75% width */
  .feature-text-col {
    width: 75%;
    display: flex;
    justify-content: flex-start;
    align-items: center;
    padding: 15px 20px;
    box-sizing: border-box;
  }

  .feature-text {
    font-family: 'SoinSans', sans-serif;
    font-weight: 400;
    font-size: 15px;
    line-height: 1.6;       /* 24px / 15px */
    color: #00312D;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 999.98px) {
    .hero-overlay-img {
      width: 320px;
      height: auto;
    }
  }

  @media (max-width: 689.98px) {
    .hero {
      min-height: auto;
      background-attachment: scroll;  /* fixed bg doesn't work well on mobile */
    }
    
    .hero-inner {
      padding: 160px 20px 20px;
    }

    .hero-col-text {
      width: 100%;
      padding-top: 4px;
    }

    .hero-heading {
      font-size: 30px;
      margin-right: 0;
    }

    .hero-desc {
      margin-right: 0;
    }

    .hero-col-image {
      width: 100%;
    }

    .hero-col-features {
      width: 100%;
      padding: 0;
    }
  }
</style>

---
// Faq.astro — FAQ section exactly matching ecociclo.es
// Source: gspb_row-id-gsbp-b8efaa8, 2 parallel Greenshift accordions
// Left: gspb_accordion-id-gsbp-5baa306 (4 items)
// Right: gspb_accordion-id-gsbp-1eb2f19 (4 items)
// Titles: background #00312D, white text
// Content: background #EAFDE7, dark green text
// Schema.org Question/Answer microdata on every item

const leftFaqs = [
  {
    q: '¿Qué tipo de servicios ofrece Ecociclo en Cataluña?',
    a: 'Ofrecemos servicios de vaciado, limpieza, retirada de residuos, gestión de residuos banales, residuos especiales líquidos, residuos especiales sólidos, limpieza de terrenos, retirada de fibrocemento y otras soluciones ambientales para empresas.',
    open: true,
  },
  {
    q: '¿Trabajáis solo con empresas o también con particulares?',
    a: 'Principalmente trabajamos con empresas, industria, locales, oficinas, almacenes y espacios profesionales, aunque también realizamos determinados servicios para particulares según el tipo de intervención.',
    open: false,
  },
  {
    q: '¿Puedo solicitar un presupuesto sin compromiso?',
    a: 'Sí. Estudiamos cada caso y preparamos una propuesta adaptada al servicio necesario y sin compromiso.',
    open: false,
  },
  {
    q: '¿Ofrecéis servicios urgentes en Barcelona?',
    a: 'Sí. Siempre que la planificación lo permita, priorizamos una respuesta ágil para que el cliente pueda resolver el problema cuanto antes.',
    open: false,
  },
];

const rightFaqs = [
  {
    q: '¿Qué tipo de espacios cubrís en Cataluña?',
    a: 'Trabajamos en naves industriales, locales, oficinas, almacenes, pisos, terrenos, parcelas, solares y otros espacios que necesitan vaciado, limpieza o retirada de residuos.',
    open: false,
  },
  {
    q: '¿Tenéis experiencia en gestión de residuos?',
    a: 'Nuestra experiencia, con <strong>más de 10 años</strong> y <strong>más de 2.500 servicios realizados</strong>, junto con una operativa rápida, profesional y orientada a empresa, nos permite ofrecer una solución más sólida y completa en Cataluña.',
    open: false,
  },
  {
    q: '¿Cómo gestionáis los residuos retirados?',
    a: 'Realizamos una clasificación profesional de todos los materiales retirados, separando los residuos por tipología y asegurando que cada fracción reciba el tratamiento adecuado según la normativa vigente, priorizando siempre la valorización frente a la eliminación.',
    open: false,
  },
  {
    q: '¿Qué diferencia a Ecociclo de otras empresas?',
    a: 'Nuestra atención personalizada, con <strong>más de 10 años de experiencia</strong> y <strong>más de 2.500 servicios realizados</strong>, junto con una operativa rápida, profesional y orientada a empresa, nos permite ofrecer una solución más sólida y completa en Cataluña.',
    open: false,
  },
];

// SVG icons matching ecociclo.es inline SVGs exactly
const questionIcon = `<svg width="15" height="15" viewBox="0 0 1024 1024" xmlns="http://www.w3.org/2000/svg"><path fill="currentColor" d="M512 16c-273.914 0-496 222.166-496 496 0 273.994 222.086 496 496 496s496-222.006 496-496c0-273.834-222.086-496-496-496zM512 912c-221.064 0-400-178.862-400-400 0-220.99 178.944-400 400-400 220.982 0 400 178.942 400 400 0 221.060-178.862 400-400 400zM726.488 401.6c0 134.104-144.842 136.168-144.842 185.726v12.674c0 13.254-10.746 24-24 24h-91.294c-13.254 0-24-10.746-24-24v-17.318c0-71.49 54.2-100.068 95.158-123.032 35.122-19.69 56.648-33.082 56.648-59.158 0-34.492-43.998-57.386-79.568-57.386-46.378 0-67.788 21.954-97.884 59.938-8.114 10.24-22.92 12.142-33.332 4.248l-55.648-42.196c-10.214-7.744-12.502-22.132-5.288-32.726 47.254-69.388 107.442-108.37 201.15-108.37 98.142 0 202.9 76.608 202.9 177.6zM596 736c0 46.318-37.682 84-84 84s-84-37.682-84-84 37.682-84 84-84 84 37.682 84 84z"/></svg>`;

const chevronIcon = `<svg width="15" height="15" viewBox="0 0 1024 1024" xmlns="http://www.w3.org/2000/svg"><path fill="currentColor" d="M512 16c274 0 496 222 496 496s-222 496-496 496-496-222-496-496 222-496 496-496zM739.8 478l-271-271c-18.8-18.8-49.2-18.8-67.8 0l-34 34c-18.8 18.8-18.8 49.2 0 67.8l203.2 203.2-203.2 203.2c-18.8 18.8-18.8 49.2 0 67.8l34 34c18.8 18.8 49.2 18.8 67.8 0l271-271c18.8-18.8 18.8-49.2 0-67.8z"/></svg>`;

const ecoCicloIconSvg = `<svg width="28" height="28" viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg"><circle cx="60" cy="60" r="55" fill="none" stroke="#65C132" stroke-width="4"/><path d="M60 20 L60 100 M20 60 L100 60" stroke="#65C132" stroke-width="4"/><circle cx="60" cy="60" r="25" fill="none" stroke="#65C132" stroke-width="3"/></svg>`;
---

<!-- ================================================================
     FAQ SECTION — 2-column parallel accordions (ecociclo.es replica)
     Left: 4 items (first open by default)
     Right: 4 items (all closed)
     Schema.org Question/Answer microdata on every item
  ================================================================ -->
<section class="faq-section" itemscope itemtype="https://schema.org/FAQPage">
  <!-- Background overlay: industrial/truck image at very low opacity -->
  <div class="faq-bg-overlay"></div>

  <div class="faq-container">
    <!-- Section Label -->
    <div class="faq-label-row">
      <span class="faq-label-icon" set:html={ecoCicloIconSvg} />
      <span class="faq-label">Centro de Ayuda y Soporte</span>
    </div>

    <!-- Heading -->
    <h2 class="faq-heading">Preguntas frecuentes sobre gestión de residuos en barcelona</h2>

    <!-- Description -->
    <p class="faq-desc">
      Resolvemos tus dudas principales para que puedas planificar el vaciado de tu inmueble o la retirada de materiales con total tranquilidad y transparencia.
    </p>

    <!-- Two-Column Accordion Grid -->
    <div class="faq-grid">
      <!-- LEFT COLUMN: 4 items -->
      <div class="faq-column">
        {leftFaqs.map((faq) => (
          <div class={`faq-item${faq.open ? ' gsopen' : ' gsclose'}`} itemscope itemtype="https://schema.org/Question">
            <meta itemprop="name" content={faq.q} />
            <div class="faq-title" role="button" tabindex="0">
              <span class="icontitle" set:html={questionIcon} />
              <div class="gs-accordion-item__heading">{faq.q}</div>
              <span class="iconfortoggle" set:html={chevronIcon} />
            </div>
            <div class="faq-content" itemscope itemtype="https://schema.org/Answer" itemprop="acceptedAnswer">
              <div class="faq-answer" itemprop="text">
                <p set:html={faq.a} />
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- RIGHT COLUMN: 4 items -->
      <div class="faq-column">
        {rightFaqs.map((faq) => (
          <div class={`faq-item${faq.open ? ' gsopen' : ' gsclose'}`} itemscope itemtype="https://schema.org/Question">
            <meta itemprop="name" content={faq.q} />
            <div class="faq-title" role="button" tabindex="0">
              <span class="icontitle" set:html={questionIcon} />
              <div class="gs-accordion-item__heading">{faq.q}</div>
              <span class="iconfortoggle" set:html={chevronIcon} />
            </div>
            <div class="faq-content" itemscope itemtype="https://schema.org/Answer" itemprop="acceptedAnswer">
              <div class="faq-answer" itemprop="text">
                <p set:html={faq.a} />
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- Vanilla JS Accordion Toggle -->
<script>
  (function() {
    document.querySelectorAll('.faq-item .faq-title').forEach(function(header) {
      header.addEventListener('click', function() {
        var item = header.closest('.faq-item');
        if (item.classList.contains('gsopen')) {
          item.classList.remove('gsopen');
          item.classList.add('gsclose');
        } else {
          item.classList.remove('gsclose');
          item.classList.add('gsopen');
        }
      });

      header.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          header.click();
        }
      });
    });
  })();
</script>

<style>
  /* ================================================================
     FAQ SECTION STYLES — Exact match to ecociclo.es
     Outer section: gspb_row-id-gsbp-b8efaa8, padding 70px 0
     Two parallel GreenShift accordions, 4 items each
     Titles: background #00312D, white text
     Content: background #EAFDE7, #00312D text
  ================================================================ */

  .faq-section {
    padding: 70px 0;
    position: relative;
    isolation: isolate;
    box-sizing: border-box;
  }

  /* ---- Background Overlay: industrial/truck image at very low opacity ---- */
  .faq-bg-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    opacity: 0.08;
    background-image: url('/images/19.webp');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    mix-blend-mode: multiply;
  }

  .faq-container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 15px;
    box-sizing: border-box;
  }

  /* ---- Label Row ---- */
  .faq-label-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-bottom: 8px;
  }

  .faq-label-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    line-height: 0;
  }

  .faq-label-icon :global(svg) {
    width: 28px;
    height: 28px;
    display: block;
  }

  .faq-label {
    color: #65C132;
    font-family: 'SoinSans', sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 1.4;
  }

  /* ---- Heading ---- */
  .faq-heading {
    font-family: 'SoinSans', sans-serif;
    font-weight: 700;
    font-size: 35px;
    line-height: 1.5;
    color: #00312D;
    text-transform: uppercase;
    text-align: center;
    margin: 0 0 10px;
  }

  /* ---- Description ---- */
  .faq-desc {
    font-family: 'SoinSans', sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 1.6;
    color: #00312D;
    text-align: center;
    margin: 0 auto 40px;
    max-width: 700px;
  }

  /* ---- Two-Column Grid ---- */
  .faq-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    max-width: 1200px;
    margin: 0 auto;
  }

  .faq-column {
    width: 50%;
    box-sizing: border-box;
    padding: 0 15px;
    display: flex;
    flex-direction: column;
  }

  /* ---- Accordion Item ---- */
  .faq-item {
    border: none;
    margin-bottom: 14px;
  }

  /* ---- Title bar ---- */
  .faq-title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0;
    padding: 18px 20px;
    background-color: #00312D;
    color: #ffffff;
    font-family: 'SoinSans', sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 1.4;
    cursor: pointer;
    border-radius: 10px;
    border: 2px solid rgba(0, 0, 0, 0.07);
    user-select: none;
    position: relative;
    z-index: 1;
    transition: background-color 0.2s ease;
  }

  .faq-title:hover {
    background-color: #004940;
  }

  /* ---- Question icon (icontitle) ---- */
  .icontitle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    padding-right: 10px;
    line-height: 0;
  }

  .icontitle :global(svg) {
    height: 16px;
    width: 16px;
    min-width: 16px;
    display: block;
  }

  /* ---- Question heading text ---- */
  .gs-accordion-item__heading {
    flex: 1;
    color: #ffffff;
    text-transform: uppercase;
    font-family: 'SoinSans', sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 1.4;
  }

  /* ---- Toggle chevron icon ---- */
  .iconfortoggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform 0.25s ease-out;
    line-height: 0;
  }

  .iconfortoggle :global(svg) {
    height: 16px;
    width: 16px;
    min-width: 16px;
    display: block;
  }

  /* Rotate chevron when open */
  .faq-item.gsopen .iconfortoggle {
    transform: rotate(90deg);
  }

  /* ---- Content (answer) wrapper ---- */
  .faq-content {
    position: relative;
    z-index: 0;
    overflow: hidden;
    transition: max-height 0.25s ease-out, opacity 0.25s ease-out;
  }

  /* CLOSED state */
  .faq-item.gsclose .faq-content {
    max-height: 0;
    opacity: 0;
  }

  /* OPEN state */
  .faq-item.gsopen .faq-content {
    max-height: 5000px;
    opacity: 1;
  }

  /* ---- Answer text ---- */
  .faq-answer {
    padding: 18px 20px 22px;
    background-color: #EAFDE7;
    border: 2px solid rgba(0, 49, 45, 0.1);
    border-top: none;
    border-radius: 0 0 10px 10px;
    overflow: hidden;
  }

  .faq-answer p {
    font-family: 'SoinSans', sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 1.6;
    color: #00312D;
    margin: 0;
    display: block;
  }

  .faq-answer p :global(strong) {
    font-weight: 700;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 999.98px) {
    .faq-answer {
      background-color: #ffffff;
    }
  }

  @media (max-width: 689.98px) {
    .faq-section {
      padding: 60px 0;
    }

    .faq-label {
      font-size: 14px;
    }

    .faq-heading {
      font-size: 26px;
    }

    .faq-desc {
      font-size: 16px;
    }

    .faq-column {
      width: 100%;
      padding: 0;
    }

    .faq-title {
      font-size: 16px;
      padding: 12px 16px;
    }

    .gs-accordion-item__heading {
      font-size: 16px;
    }

    .faq-answer {
      background-color: #ffffff;
    }

    .faq-answer p {
      font-size: 16px;
    }
  }
</style>

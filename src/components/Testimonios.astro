<style>
  /* ================================================================
     TESTIMONIOS SECTION
     Matches ecociclo.es gspb_row-id-gsbp-a640774
     Transparent background — page bg shows through
     White review cards with dark text
  ================================================================ */

  .testimonios-section {
    padding: 70px 0;
    position: relative;
    box-sizing: border-box;
    background: transparent;
  }

  .testimonios-container {
    max-width: var(--container-max, 1290px);
    margin: 0 auto;
    padding: 0 35px;
    box-sizing: border-box;
  }

  /* ---- Label Row ---- */
  .testimonios-label-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-bottom: 8px;
  }

  .testimonios-label-icon {
    width: 28px;
    height: 28px;
    display: inline-block;
    vertical-align: middle;
    box-sizing: border-box;
    max-width: 100%;
  }

  .testimonios-label {
    color: #65C132;
    font-family: 'SoinSans', sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 1.4;
  }

  /* ---- Heading ---- */
  .testimonios-heading {
    font-family: 'SoinSans', sans-serif;
    font-weight: 700;
    font-size: 36px;
    line-height: 1.3;
    color: #00312D;
    text-transform: uppercase;
    text-align: center;
    margin: 0 0 48px;
  }

  /* ---- Review Grid (3 columns on desktop) ---- */
  .testimonios-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  /* ---- Review Card ---- */
  .review-card {
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 4px;
    padding: 20px;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* ---- Review Header ---- */
  .review-header {
    display: flex;
    align-items: flex-start;
    gap: 8px;
  }

  .platform-icon {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .review-profile {
    display: flex;
    align-items: center;
    gap: 10px;
    flex: 1;
    min-width: 0;
  }

  .profile-img {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    flex-shrink: 0;
    display: block;
  }

  .reviewer-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .reviewer-name {
    font-family: 'SoinSans', sans-serif;
    font-weight: 700;
    font-size: 14px;
    line-height: 1.3;
    color: #000000;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .review-date {
    font-family: 'SoinSans', sans-serif;
    font-weight: 400;
    font-size: 13px;
    font-style: normal;
    line-height: 1.3;
    color: #666666;
  }

  /* ---- Review Stars ---- */
  .review-stars {
    display: flex;
    gap: 3px;
  }

  .review-stars svg {
    display: block;
    flex-shrink: 0;
  }

  /* ---- Review Text ---- */
  .review-text {
    font-family: 'SoinSans', sans-serif;
    font-weight: 400;
    font-size: 14px;
    line-height: 1.5;
    color: #333333;
    margin: 0;
  }

  /* ===== RESPONSIVE ===== */

  /* Tablet: 2 columns */
  @media (max-width: 999.98px) {
    .testimonios-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Mobile: stack vertically */
  @media (max-width: 689.98px) {
    .testimonios-section {
      padding: 50px 0;
    }

    .testimonios-container {
      padding: 0 20px;
    }

    .testimonios-grid {
      grid-template-columns: 1fr;
      gap: 16px;
      max-width: 500px;
      margin-left: auto;
      margin-right: auto;
    }

    .testimonios-label {
      font-size: 14px;
    }

    .testimonios-heading {
      font-size: 22px;
      margin-bottom: 32px;
    }

    .review-card {
      padding: 16px;
    }
  }
</style>

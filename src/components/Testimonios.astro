---
// Testimonios.astro — Testimonios section extracted from ecociclo.es
// Source: gspb_row-id-gsbp-a640774, h=334, bg #242f3b
// Trustindex Google review carousel (slider layout) + static fallback cards
---

<section class="testimonios-section">
  <div class="testimonios-container">
    <!-- Section Label -->
    <div class="testimonios-label-row">
      <img
        src="/images/ECOCICLO.webp"
        alt=""
        width="28"
        height="28"
        class="testimonios-label-icon"
        loading="lazy"
        decoding="async"
      />
      <span class="testimonios-label">Testimonios</span>
    </div>

    <!-- Heading -->
    <h2 class="testimonios-heading">Confianza avalada por más de 2.500 servicios</h2>

    <!-- Static Review Cards (matching Trustindex output) -->
    <div class="testimonios-grid">
      <!-- Card 1 -->
      <div class="review-card">
        <div class="review-header">
          <div class="review-avatar">
            <span class="avatar-initial">J</span>
          </div>
          <div class="review-meta">
            <div class="review-name">Jordi M.</div>
            <div class="review-stars">
              <span class="star filled">★</span>
              <span class="star filled">★</span>
              <span class="star filled">★</span>
              <span class="star filled">★</span>
              <span class="star filled">★</span>
            </div>
          </div>
          <div class="review-platform">
            <svg width="20" height="20" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
          </div>
        </div>
        <div class="review-body">
          <p>"Servicio excelente y muy profesional. Gestionaron todos los residuos de nuestra nave industrial en tiempo récord. Muy recomendables."</p>
        </div>
      </div>

      <!-- Card 2 -->
      <div class="review-card">
        <div class="review-header">
          <div class="review-avatar">
            <span class="avatar-initial">M</span>
          </div>
          <div class="review-meta">
            <div class="review-name">María G.</div>
            <div class="review-stars">
              <span class="star filled">★</span>
              <span class="star filled">★</span>
              <span class="star filled">★</span>
              <span class="star filled">★</span>
              <span class="star filled">★</span>
            </div>
          </div>
          <div class="review-platform">
            <svg width="20" height="20" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
          </div>
        </div>
        <div class="review-body">
          <p>"Contactamos con Ecociclo para una limpieza de Diógenes y fueron muy discretos y eficientes. Trato inmejorable y resultados impecables."</p>
        </div>
      </div>

      <!-- Card 3 -->
      <div class="review-card">
        <div class="review-header">
          <div class="review-avatar">
            <span class="avatar-initial">A</span>
          </div>
          <div class="review-meta">
            <div class="review-name">Antoni R.</div>
            <div class="review-stars">
              <span class="star filled">★</span>
              <span class="star filled">★</span>
              <span class="star filled">★</span>
              <span class="star filled">★</span>
              <span class="star filled">★</span>
            </div>
          </div>
          <div class="review-platform">
            <svg width="20" height="20" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
          </div>
        </div>
        <div class="review-body">
          <p>"Llevamos años trabajando con ellos para la retirada de residuos especiales. Siempre cumplen plazos y normativas. Un equipo de confianza."</p>
        </div>
      </div>
    </div>

    <!-- Google Rating Summary -->
    <div class="testimonios-rating-summary">
      <div class="rating-stars-row">
        <span class="big-star filled">★</span>
        <span class="big-star filled">★</span>
        <span class="big-star filled">★</span>
        <span class="big-star filled">★</span>
        <span class="big-star filled">★</span>
      </div>
      <p class="rating-text">
        <strong>Valoración 5.0</strong> — basada en <strong>+150 reseñas</strong> en Google
      </p>
    </div>
  </div>
</section>

<!-- Trustindex Loader Script (loads asynchronously, static cards shown until then) -->
<script>
  (function() {
    if (window.__trustindexLoaded) return;
    window.__trustindexLoaded = true;
    
    const script = document.createElement('script');
    script.src = 'https://cdn.trustindex.io/loader.js?ver=1';
    script.async = true;
    script.defer = true;
    document.head.appendChild(script);
  })();
</script>

<style>
  /* ================================================================
     TESTIMONIOS SECTION STYLES — Matches ecociclo.es
     Outer section: gspb_row-id-gsbp-a640774, bg #242f3b
     Static review cards as fallback for Trustindex carousel
  ================================================================ */

  .testimonios-section {
    padding: 70px 0 90px;
    position: relative;
    box-sizing: border-box;
    background-color: #242f3b;
  }

  .testimonios-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 15px;
    box-sizing: border-box;
  }

  /* ---- Label Row ---- */
  .testimonios-label-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-bottom: 8px;
  }

  .testimonios-label-icon {
    width: 28px;
    height: auto;
    display: inline-block;
    vertical-align: top;
    box-sizing: border-box;
    max-width: 100%;
  }

  .testimonios-label {
    color: #65C132;
    font-family: 'SoinSans', sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 1.4;
  }

  /* ---- Heading ---- */
  .testimonios-heading {
    font-family: 'SoinSans', sans-serif;
    font-weight: 700;
    font-size: 35px;
    line-height: 1.5;
    color: #ffffff;
    text-transform: uppercase;
    text-align: center;
    margin: 0 0 40px;
  }

  /* ---- Review Grid (3 columns) ---- */
  .testimonios-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 40px;
  }

  /* ---- Review Card ---- */
  .review-card {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 12px;
    padding: 24px;
    transition: transform 0.2s ease, background 0.2s ease;
  }

  .review-card:hover {
    background: rgba(255, 255, 255, 0.12);
    transform: translateY(-2px);
  }

  .review-header {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 16px;
  }

  .review-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: linear-gradient(135deg, #65C132, #45891E);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .avatar-initial {
    color: #ffffff;
    font-family: 'SoinSans', sans-serif;
    font-weight: 700;
    font-size: 18px;
    line-height: 1;
  }

  .review-meta {
    flex: 1;
  }

  .review-name {
    color: #ffffff;
    font-family: 'SoinSans', sans-serif;
    font-weight: 700;
    font-size: 16px;
    line-height: 1.4;
    margin-bottom: 4px;
  }

  .review-stars {
    display: flex;
    gap: 2px;
  }

  .star {
    font-size: 16px;
    line-height: 1;
  }

  .star.filled {
    color: #f1c40f;
  }

  .review-platform {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .review-body p {
    color: rgba(255, 255, 255, 0.85);
    font-family: 'SoinSans', sans-serif;
    font-weight: 400;
    font-size: 15px;
    line-height: 1.6;
    margin: 0;
    font-style: italic;
  }

  /* ---- Rating Summary ---- */
  .testimonios-rating-summary {
    text-align: center;
    padding: 20px 0 0;
  }

  .rating-stars-row {
    display: flex;
    justify-content: center;
    gap: 4px;
    margin-bottom: 10px;
  }

  .big-star {
    font-size: 28px;
    line-height: 1;
  }

  .big-star.filled {
    color: #f1c40f;
  }

  .rating-text {
    color: rgba(255, 255, 255, 0.8);
    font-family: 'SoinSans', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 1.4;
    margin: 0;
  }

  .rating-text strong {
    font-weight: 700;
    color: #ffffff;
  }

  /* Trustindex widget override (when loaded) */
  .testimonios-grid.ti-loaded {
    display: none;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 999.98px) {
    .testimonios-grid {
      grid-template-columns: 1fr;
      gap: 16px;
      max-width: 600px;
      margin-left: auto;
      margin-right: auto;
    }
  }

  @media (max-width: 689.98px) {
    .testimonios-section {
      padding: 50px 0 70px;
    }

    .testimonios-label {
      font-size: 14px;
    }

    .testimonios-heading {
      font-size: 26px;
      margin-bottom: 30px;
    }

    .review-card {
      padding: 20px;
    }

    .review-body p {
      font-size: 14px;
    }
  }
</style>

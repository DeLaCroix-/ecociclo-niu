<style>
  /* ================================================================
     FILOSOFÍA SECTION — Exact reproduction of ecociclo.es
     Greenshift block gspb_row-id-gsbp-d281619
     y=727, h=734, padding: 50px 0 40px
  ================================================================ */

  .filosofia {
    padding: 50px 0 40px;
  }

  .filosofia-inner {
    width: 100%;
    max-width: 1290px;
    margin: 0 auto;
    padding: 0 20px;
    box-sizing: border-box;
  }

  .filosofia-row {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
  }

  /* ---- LEFT COL: Main Image (55%) ---- */
  .filosofia-col-image {
    width: 55%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    padding: 0 20px 0 0;
    box-sizing: border-box;
  }

  .filosofia-main-img {
    display: inline-block;
    width: 458px;
    height: auto;
    max-width: 100%;
    vertical-align: top;
    box-sizing: border-box;
  }

  /* ---- RIGHT COL: Content (45%) ---- */
  .filosofia-col-content {
    width: 45%;
    display: flex;
    flex-direction: column;
    row-gap: 10px;
    padding: 50px 20px 15px;
    box-sizing: border-box;
    position: relative;
  }

  /* ---- Overlay image (absolute top-right, rotated) ---- */
  .filosofia-overlay-img-wrap {
    position: absolute;
    top: 0;
    right: 0;
    z-index: 0;
    pointer-events: none;
  }

  .filosofia-overlay-img {
    display: inline-block;
    width: 62px;
    height: 110px;
    vertical-align: top;
    box-sizing: border-box;
    max-width: 100%;
    transform: rotate(30deg);
    opacity: 0.85;
  }

  /* ---- Label row: icon + span ---- */
  .filosofia-label-row {
    display: flex;
    align-items: center;
    gap: 10.72px;
    position: relative;
    z-index: 1;
  }

  .filosofia-label-icon {
    width: 28px;
    height: 28px;
    display: inline-block;
    box-sizing: border-box;
    object-fit: fill;
    vertical-align: top;
  }

  .filosofia-label {
    display: block;
    font-family: 'SoinSans', sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 1.6;        /* 28.8px / 18px */
    color: #65C132;
    letter-spacing: 6px;
  }

  /* ---- H2 heading ---- */
  .filosofia-heading {
    font-family: 'SoinSans', sans-serif;
    font-weight: 700;
    font-size: 35px;
    line-height: 1.5;         /* 52.5px / 35px */
    color: #00312D;
    text-transform: uppercase;
    margin: 0;
    position: relative;
    z-index: 1;
  }

  /* ---- Description text ---- */
  .filosofia-desc {
    font-family: 'SoinSans', sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 1.6;         /* 28.8px / 18px */
    color: #00312D;
    margin: 0;
    padding: 10px 0 20px;
    position: relative;
    z-index: 1;
  }

  .filosofia-desc strong {
    font-weight: 700;
  }

  /* ---- Pills grid (2x2) ---- */
  .filosofia-pills {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    row-gap: 20px;
    column-gap: 35px;
    box-sizing: border-box;
    position: relative;
    z-index: 1;
  }

  .filosofia-pill {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 7px;
    box-sizing: border-box;
  }

  .filosofia-pill-icon {
    display: block;
    width: 30px;
    height: 30px;
    min-width: 30px;
    flex-shrink: 0;
    vertical-align: middle;
  }

  .filosofia-pill-icon path {
    fill: #36611C;
  }

  .filosofia-pill-text {
    font-family: 'SoinSans', sans-serif;
    font-weight: 700;
    font-size: 18px;
    line-height: 1.6;         /* 28.8px / 18px */
    color: #00312D;
    margin: 0;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 999.98px) {
    .filosofia-main-img {
      width: 100%;
    }
  }

  @media (max-width: 689.98px) {

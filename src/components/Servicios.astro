---
// Servicios.astro — SwiperJS carousel matching ecociclo.es original
// Greenshift block gspb_row-id-gsbp-b0a856b
// Background overlay: 19.webp at 0.18 opacity
// 3 slides visible desktop, 1 mobile, 8 service cards

import 'swiper/css';
import 'swiper/css/navigation';
import 'swiper/css/pagination';

const services = [
  {
    title: 'VACIADOS Y LIMPIEZA',
    desc: 'Vaciado de naves industriales, pisos, trasteros, locales y oficina.',
    href: '/servicios/vaciado-de-naves-industriales-pisos-y-locales-en-barcelona',
  },
  {
    title: 'GESTIÓN DE RESIDUOS BANALES',
    desc: 'Contenedores para la gestión de residuos industriales',
    href: '/servicios/gestion-de-residuos-banales-en-barcelona',
  },
  {
    title: 'RESIDUOS ESPECIALES LÍQUIDOS',
    desc: 'Gestión y transporte de residuos especiales líquidos',
    href: '/servicios/transporte-de-residuos-especiales-liquidos-en-barcelona',
  },
  {
    title: 'RESIDUOS ESPECIALES SÓLIDOS',
    desc: 'Gestión y transporte de residuos especiales sólidos con todas las garantías de seguridad.',
    href: '/servicios/transporte-de-residuos-especiales-solidos-en-barcelona',
  },
  {
    title: 'RETIRADA DE FIBROCEMENTO',
    desc: 'Servicio profesional de retirada de fibrocemento y uralita en Barcelona',
    href: '/servicios/retirada-de-fibrocemento-en-barcelona',
  },
  {
    title: 'LIMPIEZA DE TERRENOS',
    desc: 'Servicio de limpieza y desbroce de terrenos y parcelas',
    href: '/servicios/limpieza-de-terrenos-y-parcelas-en-barcelona',
  },
  {
    title: 'LIMPIEZA DE síndrome de DIÓGENES',
    desc: 'Limpieza de lugares afectados por el síndrome de Diógenes',
    href: '/servicios/limpieza-de-diogenes-en-barcelona',
  },
  {
    title: 'trasvases y acondicionamiento',
    desc: 'Realizamos el trasvase de residuos peligrosos y no peligrosos',
    href: '/servicios/acondicionamiento-de-residuos-peligrosos-en-barcelona',
  },
];

function formatTitle(title: string): { line1: string; line2: string } {
  const words = title.split(' ');
  const mid = Math.ceil(words.length / 2);
  return {
    line1: words.slice(0, mid).join(' '),
    line2: words.slice(mid).join(' '),
  };
}
---

<!-- ================================================================
     SERVICIOS SECTION — SwiperJS carousel matching ecociclo.es
     Greenshift block gspb_row-id-gsbp-b0a856b
     Background overlay 19.webp at 0.18 opacity
  ================================================================ -->
<section class="servicios-section">

  <!-- Background overlay: 19.webp at 0.18 opacity -->
  <div class="servicios-bg-overlay"></div>

  <div class="servicios-container">

    <!-- ===== Section Header (55% / 45% split) ===== -->
    <div class="servicios-header">
      <!-- Left: label + H2 -->
      <div class="servicios-header__left">
        <div class="servicios-label-row">
          <img
            src="/images/servicios/ECOCICLO.webp"
            alt=""
            width="28"
            height="28"
            class="servicios-label-icon"
            loading="lazy"
            decoding="async"
          />
          <span class="servicios-label">Soluciones integrales a medida</span>
        </div>
        <h2 class="servicios-title">
          <strong>¿QUÉ HACEMOS</strong><br /><strong>EN ECOCICLO?</strong>
        </h2>
      </div>

      <!-- Right: description -->
      <div class="servicios-header__right">
        <p class="servicios-header-desc">
          Nos encargamos del <strong>vaciado de naves industriales, locales y oficinas</strong>, asegurando una gestión de residuos responsable y eficiente.
        </p>
      </div>
    </div>

    <!-- ===== Swiper Carousel ===== -->
    <div class="swiper servicios-swiper">
      <div class="swiper-wrapper">
        {
          services.map((s) => {
            const { line1, line2 } = formatTitle(s.title);
            return (
              <div class="swiper-slide">
                <div class="servicio-card">
                  <!-- Icon box -->
                  <div class="servicio-card__icon-wrap">
                    <div class="servicio-card__icon-box">
                      <img
                        src="/images/servicios/35.webp"
                        alt=""
                        width="40"
                        height="40"
                        loading="lazy"
                        decoding="async"
                      />
                    </div>
                  </div>

                  <!-- Title -->
                  <h3 class="servicio-card__title">
                    <strong>{line1}</strong><br /><strong>{line2}</strong>
                  </h3>

                  <!-- Description -->
                  <p class="servicio-card__desc">{s.desc}</p>

                  <!-- Button -->
                  <div class="servicio-card__btn-wrap">
                    <a href={s.href} class="servicio-card__btn">Ver Servicio</a>
                  </div>
                </div>
              </div>
            );
          })
        }
      </div>

      <!-- Navigation -->
      <div class="swiper-pagination"></div>
      <div class="swiper-button-prev"></div>
      <div class="swiper-button-next"></div>
    </div>

    <!-- ===== "Ver todos los servicios" CTA ===== -->
    <div class="servicios-cta">
      <a href="/servicios-de-gestion-ambiental" class="servicios-cta__btn">
        <strong>Ver todos los servicios</strong>
      </a>
    </div>

  </div>
</section>

<script>
  import Swiper from 'swiper';
  import { Navigation, Pagination, Mousewheel } from 'swiper/modules';

  new Swiper('.servicios-swiper', {
    modules: [Navigation, Pagination, Mousewheel],
    slidesPerView: 3,
    slidesPerGroup: 1,
    spaceBetween: 10,
    speed: 400,
    loop: false,
    mousewheel: {
      forceToAxis: true,
    },
    navigation: {
      nextEl: '.servicios-swiper .swiper-button-next',
      prevEl: '.servicios-swiper .swiper-button-prev',
    },
    pagination: {
      el: '.servicios-swiper .swiper-pagination',
      clickable: true,
    },
    breakpoints: {
      0: {
        slidesPerView: 1,
        spaceBetween: 10,
      },
      690: {
        slidesPerView: 1,
        spaceBetween: 10,
      },
      1000: {
        slidesPerView: 3,
        spaceBetween: 10,
      },
    },
  });
</script>

<style>
  /* ================================================================
     SERVICIOS SECTION STYLES
     Matching ecociclo.es Greenshift row gspb_row-id-gsbp-b0a856b
  ================================================================ */

  /* ---- Section Wrapper ---- */
  .servicios-section {
    position: relative;
    isolation: isolate;
    padding: 15px min(3vw, 20px);
    box-sizing: border-box;
  }

  /* ---- Background Overlay: 19.webp at 0.18 opacity ---- */
  .servicios-bg-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    opacity: 0.18;
    background-image: url('/images/19.webp');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  /* ---- Inner Container (max-width 1200px) ---- */
  .servicios-container {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  /* ================================================================
     HEADER — 55% / 45% split row
  ================================================================ */
  .servicios-header {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 30px;
    padding-top: 70px;
  }

  .servicios-header__left {
    width: 55%;
    display: flex;
    flex-direction: column;
    row-gap: 10px;
    padding-right: 160px;
    box-sizing: border-box;
  }

  .servicios-header__right {
    width: 45%;
    display: flex;
    align-items: center;
    padding-left: 50px;
    box-sizing: border-box;
  }

  /* ---- Label row: icon + text ---- */
  .servicios-label-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 0;
  }

  .servicios-label-icon {
    width: 28px;
    height: auto;
    display: inline-block;
    vertical-align: top;
    box-sizing: border-box;
    max-width: 100%;
  }

  .servicios-label {
    color: #65C132;
    font-family: 'SoinSans', sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 1.4;
  }

  /* ---- H2 Title ---- */
  .servicios-title {
    font-family: 'SoinSans', sans-serif;
    font-weight: 700;
    font-size: 35px;
    line-height: 1.5;
    color: #00312D;
    text-transform: uppercase;
    margin: 0;
  }

  .servicios-title strong {
    font-weight: 700;
  }

  /* ---- Header Description ---- */
  .servicios-header-desc {
    font-family: 'SoinSans', sans-serif;
    font-weight: 400;
    font-size: 15px;
    line-height: 1.5;
    color: #192a3d;
    margin: 0;
    text-align: right;
  }

  .servicios-header-desc strong {
    font-weight: 700;
  }

  /* ================================================================
     SWIPER CAROUSEL
  ================================================================ */
  .servicios-swiper {
    width: 100%;
    padding-bottom: 40px; /* space for pagination */
    overflow: hidden;
  }

  .servicios-swiper .swiper-slide {
    height: auto;
    box-sizing: border-box;
  }

  /* ---- Navigation Arrows (hidden until hover, matching original) ---- */
  .servicios-swiper .swiper-button-prev,
  .servicios-swiper .swiper-button-next {
    top: 40%;
    width: 44px;
    height: 44px;
    line-height: 44px;
    visibility: hidden;
    background-color: rgba(101, 194, 50, 0.34);
    color: #ffffff;
    box-shadow: 20px 20px 60px rgba(88, 102, 125, 0.37);
    border-radius: 50%;
    transition: visibility 0.2s, opacity 0.2s;
  }

  .servicios-swiper:hover .swiper-button-prev,
  .servicios-swiper:hover .swiper-button-next {
    visibility: visible;
  }

  .servicios-swiper .swiper-button-prev::after,
  .servicios-swiper .swiper-button-next::after {
    font-size: 20px;
  }

  /* ---- Pagination Bullets ---- */
  .servicios-swiper .swiper-pagination {
    bottom: 2px !important;
    text-align: center !important;
  }

  .servicios-swiper .swiper-pagination-bullet {
    width: 7px;
    height: 7px;
    border-radius: 100px;
    background-color: #65C132;
    opacity: 1;
    transition: width 0.4s ease-out;
  }

  .servicios-swiper .swiper-pagination-bullet-active {
    width: 21px;
    background-color: #45891E;
  }

  /* ================================================================
     SERVICE CARDS
     Dark bg #00312D → hover #EAFDE7
  ================================================================ */
  .servicio-card {
    background-color: #00312D;
    border: 1px solid #65C132;
    border-radius: 15px;
    padding: 40px;
    margin: 5px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
    box-sizing: border-box;
    height: 100%;
    transition: background-color 0.2s ease, transform 0.2s ease;
    position: relative;
  }

  .servicio-card:hover {
    background-color: #EAFDE7;
    transform: scale(1.01);
  }

  /* Hover text color changes */
  .servicio-card:hover .servicio-card__title,
  .servicio-card:hover .servicio-card__title strong {
    color: #00312D !important;
  }

  .servicio-card:hover .servicio-card__desc {
    color: #00312D !important;
  }

  /* ---- Icon Box ---- */
  .servicio-card__icon-wrap {
    display: flex;
    justify-content: flex-start;
    margin-bottom: 0;
    flex-shrink: 0;
  }

  .servicio-card__icon-box {
    display: inline-flex;
    background-color: #65C132;
    border-radius: 10px;
    padding: 20px;
    border: 0 solid #65C132;
  }

  .servicio-card__icon-box img {
    height: 40px !important;
    width: 40px !important;
    min-width: 40px !important;
    display: block;
    margin: 0 !important;
  }

  /* ---- Card Title (H3) ---- */
  .servicio-card__title {
    font-family: 'SoinSans', sans-serif;
    font-weight: 700;
    font-size: 25px;
    line-height: 1.2;
    color: #ffffff;
    margin: 0;
    padding-top: 20px;
    padding-bottom: 10px;
    transition: color 0.5s ease-out;
    flex-shrink: 0;
  }

  .servicio-card__title strong {
    font-weight: 700;
    color: inherit;
  }

  /* ---- Card Description ---- */
  .servicio-card__desc {
    font-family: 'SoinSans', sans-serif;
    font-weight: 400;
    font-size: 15px;
    line-height: 1.5;
    color: #ffffff;
    margin: 0;
    padding-bottom: 15px;
    flex: 1 0 auto;
    transition: color 0.2s ease;
  }

  /* ---- Card Button ---- */
  .servicio-card__btn-wrap {
    width: 100%;
    margin-top: auto;
    flex-shrink: 0;
  }

  .servicio-card__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    box-sizing: border-box;
    background-color: #45891E;
    color: #ffffff;
    font-family: 'SoinSans', sans-serif;
    font-weight: 500;
    font-size: 15px;
    line-height: 1.6;
    text-decoration: none;
    text-align: center;
    padding: 5px 20px;
    border-radius: 20px;
    border: 0 none;
    transition: background-color 0.12s cubic-bezier(0.455, 0.03, 0.515, 0.955),
                color 0.12s cubic-bezier(0.455, 0.03, 0.515, 0.955);
  }

  .servicio-card__btn:hover {
    background-color: #65C132;
    color: #00312D;
  }

  /* ================================================================
     "VER TODOS LOS SERVICIOS" CTA
  ================================================================ */
  .servicios-cta {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    row-gap: 20px;
    padding-bottom: 70px;
  }

  .servicios-cta__btn {
    display: inline-block;
    align-self: center;
    padding: 10px 25px;
    background-color: #65C132;
    color: #ffffff;
    font-family: 'SoinSans', sans-serif;
    font-weight: 700;
    font-size: 15px;
    line-height: 1.5;
    text-decoration: none;
    text-align: center;
    border-radius: 30px;
    border: 0 none;
    box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.02);
    transition: box-shadow 0.25s, transform 0.25s, background-color 0.25s;
    cursor: pointer;
  }

  .servicios-cta__btn:hover {
    box-shadow: 0 8px 15px 0 rgba(0, 0, 0, 0.25);
    transform: translateY(-3px);
    color: #ffffff;
    background-color: #45891E;
  }

  .servicios-cta__btn:active {
    box-shadow: 0 1px 0 0 rgba(0, 0, 0, 0.25);
    transform: translateY(3px);
  }

  .servicios-cta__btn strong {
    font-weight: 700;
  }

  /* ================================================================
     RESPONSIVE
  ================================================================ */
  @media (max-width: 999.98px) {
    .servicios-header__left {
      width: 100%;
      padding-right: 0;
      margin-bottom: 20px;
    }

    .servicios-header__right {
      width: 100%;
      padding-left: 0;
    }

    .servicios-header-desc {
      text-align: left;
    }
  }

  @media (max-width: 689.98px) {
    .servicios-section {
      padding: 15px 20px 20px;
    }

    .servicios-header {
      padding-top: 0;
    }

    .servicios-label {
      font-size: 14px;
    }

    .servicios-title {
      font-size: 28px;
    }

    .servicio-card {
      padding: 30px;
    }

    .servicios-swiper .swiper-button-prev,
    .servicios-swiper .swiper-button-next {
      display: none;
    }
  }
</style>

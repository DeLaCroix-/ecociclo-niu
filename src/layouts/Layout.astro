---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  description,
  canonical = 'https://ecociclonew.netlify.app',
  ogImage = 'https://ecociclo.es/wp-content/uploads/2026/03/cropped-Ecociclo-Logo-Horizontal-scaled-1.png',
} = Astro.props;

const currentPath = Astro.url.pathname;

const navItems = [
  { label: 'Inicio', href: '/' },
  { label: 'Quiénes somos', href: '/empresa-de-gestion-de-residuos' },
  { 
    label: 'Servicios', 
    href: '/servicios-de-gestion-ambiental',
    children: [
      { label: 'Vaciado de naves industriales, pisos y locales', href: '/servicios/vaciado-de-naves-industriales-pisos-y-locales-en-barcelona' },
      { label: 'Limpieza de Diógenes', href: '/servicios/limpieza-de-diogenes-en-barcelona' },
      { label: 'Trasvases y acondicionamiento de residuos peligrosos y no peligrosos', href: '/servicios/acondicionamiento-de-residuos-peligrosos-en-barcelona' },
      { label: 'Residuos Banales', href: '/servicios/gestion-de-residuos-banales-en-barcelona' },
      { label: 'Residuos Especiales Sólidos', href: '/servicios/transporte-de-residuos-especiales-solidos-en-barcelona' },
      { label: 'Residuos Especiales Líquidos', href: '/servicios/transporte-de-residuos-especiales-liquidos-en-barcelona' },
      { label: 'Retirada de Fibrocemento', href: '/servicios/retirada-de-fibrocemento-en-barcelona' },
      { label: 'Limpieza de Terrenos', href: '/servicios/limpieza-de-terrenos-y-parcelas-en-barcelona' },
    ]
  },
  { label: 'Productos', href: '/productos-sdr' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contacto', href: '/contacto' },
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5" />
    <link rel="icon" type="image/png" href="https://ecociclo.es/wp-content/uploads/2026/03/cropped-Ecociclo-Logo-Horizontal-scaled-1.png" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO -->
    <title>{title} | Ecociclo</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    
    <!-- Open Graph -->
    <meta property="og:locale" content="es_ES" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | Ecociclo`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Ecociclo" />
    <meta property="og:image" content={ogImage} />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Ecociclo`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Google Fonts for button only -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;700&display=swap" rel="stylesheet" />
  </head>
  
  <body>
    <!-- ===== HEADER: transparent over hero ===== -->
    <header class="site-header">
      <!-- Top bar: phone + email -->
      <div class="header-top">
        <div class="container-site">
          <p class="header-contact">
            <a href="tel:+34692063213">692 06 32 13</a> / <a href="mailto:info@ecociclo.es"><strong>info@ecociclo.es</strong></a>
          </p>
        </div>
      </div>

      <!-- Main nav bar: transparent -->
      <div class="header-main">
        <div class="container-site header-main-grid">
          <!-- Logo -->
          <a href="/" class="logo-link">
            <img src="/images/logo.webp" alt="Ecociclo" class="logo-img" width="2560" height="949" />
          </a>

          <!-- Desktop Nav -->
          <nav class="desktop-nav">
            {navItems.map((item) => (
              <div class="nav-item-wrapper">
                <a href={item.href} class={`nav-link${currentPath === item.href ? ' active' : ''}${item.children ? ' has-dropdown' : ''}`}>
                  {item.label}
                  {item.children && <span class="dropdown-arrow">▾</span>}
                </a>
                {item.children && (
                  <div class="dropdown">
                    {item.children.map((child) => (
                      <a href={child.href} class="dropdown-link">{child.label}</a>
                    ))}
                  </div>
                )}
              </div>
            ))}
          </nav>

          <!-- CTA Button -->
          <a href="tel:692063213" class="cta-btn">Llámanos</a>

          <!-- Search icon -->
          <button class="search-btn" aria-label="Buscar">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          </button>

          <!-- Mobile toggle -->
          <button class="mobile-toggle" id="mobile-toggle" aria-label="Menú">
            <span></span><span></span><span></span>
          </button>
        </div>
      </div>

      <!-- Mobile panel -->
      <div class="mobile-panel" id="mobile-panel">
        <div class="mobile-panel-inner">
          {navItems.map((item) => (
            <div>
              <a href={item.href} class="mobile-link">{item.label}</a>
              {item.children?.map((child) => (
                <a href={child.href} class="mobile-sublink">{child.label}</a>
              ))}
            </div>
          ))}
          <a href="tel:692063213" class="mobile-cta">Llámanos</a>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-container">
        <p style="color:white;text-align:center;padding:40px">Footer — paso 2</p>
      </div>
    </footer>

    <script>
      document.getElementById('mobile-toggle')?.addEventListener('click', () => {
        document.getElementById('mobile-panel')?.classList.toggle('open');
      });
    </script>
  </body>
</html>

<style is:global>
  /* ===== FONTS ===== */
  @font-face {
    font-family: 'SoinSans';
    src: url('/fonts/Soin-Sans-Pro-Roman.ttf') format('truetype');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'SoinSans';
    src: url('/fonts/Soin-Sans-Pro-Medium.ttf') format('truetype');
    font-weight: 500;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'SoinSans';
    src: url('/fonts/Soin-Sans-Pro-Bold.ttf') format('truetype');
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }

  /* ===== HEADER ===== */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
  }

  /* Top bar */
  .header-top {
    background: #00312D;
    height: 40px;
    display: flex;
    align-items: center;
  }

  .header-contact {
    margin: 0;
    font-family: 'SoinSans', sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 1;
    color: #fff;
    text-align: left;
  }
  .header-contact a {
    color: #fff;
    text-decoration: none;
  }
  .header-contact a:hover {
    color: #65C132;
  }

  /* Main bar - TRANSPARENT */
  .header-main {
    height: 100px;
    display: flex;
    align-items: center;
    transition: background 0.2s;
  }
  .header-main-grid {
    display: flex;
    align-items: center;
    gap: 0;
  }

  /* Logo */
  .logo-link {
    flex-shrink: 0;
    margin-right: auto;
  }
  .logo-img {
    height: 75px;
    width: auto;
    display: block;
  }

  /* Desktop Nav */
  .desktop-nav {
    display: flex;
    align-items: center;
    gap: 0;
    margin-right: 30px;
  }
  .nav-item-wrapper {
    position: relative;
  }
  .nav-link {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 0 15px;
    height: 100px;
    font-family: 'SoinSans', sans-serif;
    font-weight: 500;
    font-size: 20px;
    text-transform: capitalize;
    color: #ffffff;
    text-decoration: none;
    transition: color 0.2s;
    white-space: nowrap;
  }
  .nav-link:hover,
  .nav-link.active {
    color: #65C132;
  }

  /* Dropdown */
  .dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    background: #45891E;
    min-width: 380px;
    padding: 8px 0;
    border-radius: 0 0 2px 2px;
    box-shadow: 0 10px 20px rgba(41,51,61,0.1);
  }
  .nav-item-wrapper:hover .dropdown {
    display: block;
  }
  .dropdown-link {
    display: block;
    padding: 10px 20px;
    font-family: 'SoinSans', sans-serif;
    font-weight: 500;
    font-size: 16px;
    color: #ffffff;
    text-decoration: none;
    border-bottom: 1px dashed rgba(255,255,255,0.1);
    transition: color 0.2s;
  }
  .dropdown-link:last-child {
    border-bottom: none;
  }
  .dropdown-link:hover {
    color: #f2f5f7;
  }

  /* CTA Button */
  .cta-btn {
    display: inline-flex;
    align-items: center;
    background: #65C132;
    color: #f2f5f7;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 500;
    font-size: 16px;
    border: none;
    border-radius: 20px;
    padding: 12px 24px;
    min-height: 40px;
    text-decoration: none;
    transition: background 0.2s;
    white-space: nowrap;
    margin-right: 12px;
  }
  .cta-btn:hover {
    background: #45891E;
  }

  /* Search */
  .search-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: #65C132;
    padding: 8px;
    display: flex;
    align-items: center;
  }

  /* Mobile toggle */
  .mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 10px;
    margin-left: 8px;
  }
  .mobile-toggle span {
    display: block;
    width: 18px;
    height: 2px;
    background: #65C132;
    border-radius: 1px;
  }

  /* Mobile panel */
  .mobile-panel {
    display: none;
    background: rgba(18,21,25,0.98);
    max-height: calc(100vh - 140px);
    overflow-y: auto;
  }
  .mobile-panel.open {
    display: block;
  }
  .mobile-panel-inner {
    padding: 20px 35px;
  }
  .mobile-link {
    display: block;
    padding: 14px 0;
    font-family: 'SoinSans', sans-serif;
    font-weight: 700;
    font-size: 20px;
    color: #fff;
    text-decoration: none;
  }
  .mobile-sublink {
    display: block;
    padding: 8px 0 8px 20px;
    font-family: 'SoinSans', sans-serif;
    font-size: 16px;
    color: rgba(255,255,255,0.8);
    text-decoration: none;
  }
  .mobile-cta {
    display: inline-block;
    margin-top: 20px;
    background: #65C132;
    color: #fff;
    padding: 12px 24px;
    border-radius: 20px;
    font-weight: 700;
    font-size: 16px;
    text-decoration: none;
  }

  /* Responsive */
  @media (max-width: 1100px) {
    .desktop-nav { display: none; }
    .cta-btn { display: none; }
    .search-btn { display: none; }
    .mobile-toggle { display: flex; }
    .header-main-grid { justify-content: space-between; }
  }
  @media (max-width: 690px) {
    .header-main { height: 80px; }
    .logo-img { height: 55px; }
    .header-contact { font-size: 16px; }
  }
</style>

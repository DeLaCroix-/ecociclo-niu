---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  description,
  canonical = 'https://ecociclonew.netlify.app',
  ogImage = 'https://ecociclo.es/wp-content/uploads/2026/03/cropped-Ecociclo-Logo-Horizontal-scaled-1.png',
} = Astro.props;

const currentPath = Astro.url.pathname;

const navItems = [
  { label: 'Inicio', href: '/', isHome: true },
  { label: 'Quiénes somos', href: '/empresa-de-gestion-de-residuos' },
  { 
    label: 'Servicios', 
    href: '/servicios-de-gestion-ambiental',
    children: [
      { label: 'Limpieza de Diógenes', href: '/servicios/limpieza-de-diogenes-en-barcelona' },
      { label: 'Trasvases y acondicionamiento de residuos peligrosos y no peligrosos', href: '/servicios/acondicionamiento-de-residuos-peligrosos-en-barcelona' },
      { label: 'Residuos Banales', href: '/servicios/gestion-de-residuos-banales-en-barcelona' },
      { label: 'Residuos Especiales Sólidos', href: '/servicios/transporte-de-residuos-especiales-solidos-en-barcelona' },
      { label: 'Residuos Especiales Líquidos', href: '/servicios/transporte-de-residuos-especiales-liquidos-en-barcelona' },
      { label: 'Retirada de Fibrocemento', href: '/servicios/retirada-de-fibrocemento-en-barcelona' },
      { label: 'Limpieza de Terrenos', href: '/servicios/limpieza-de-terrenos-y-parcelas-en-barcelona' },
    ]
  },
  { label: 'Productos', href: '/productos-sdr' },
  { label: 'Contacto', href: '/contacto' },
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5" />
    <link rel="icon" type="image/png" href="https://ecociclo.es/wp-content/uploads/2026/03/cropped-Ecociclo-Logo-Horizontal-scaled-1.png" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO -->
    <title>{title} | Ecociclo</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    
    <!-- Open Graph -->
    <meta property="og:locale" content="es_ES" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | Ecociclo`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Ecociclo" />
    <meta property="og:image" content={ogImage} />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Ecociclo`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Google Fonts: Plus Jakarta Sans -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@500;700&display=swap" rel="stylesheet" />
  </head>
  
  <body>
    <!-- ===== HEADER (Blocksy type-1 clone) ===== -->
    <header class="header-blocksy" data-header="type-1">
      <!-- Sticky container -->
      <div class="header-sticky">
        <!-- Top Row: phone + email -->
        <div class="header-top-row">
          <div class="header-container">
            <div class="header-top-content">
              <div class="header-contact-text">
                <a href="tel:+34692063213">692 06 32 13</a> / <a href="mailto:info@ecociclo.es"><strong>info@ecociclo.es</strong></a>
              </div>
            </div>
          </div>
        </div>

        <!-- Middle Row: logo + nav + actions -->
        <div class="header-middle-row">
          <div class="header-container header-middle-grid">
            <!-- Logo -->
            <div class="header-logo-col">
              <div class="site-branding">
                <a href="/" class="site-logo-container">
                  <img 
                    src="/images/logo.webp" 
                    class="default-logo" 
                    alt="Ecociclo"
                    width="2560"
                    height="949"
                  />
                </a>
              </div>
            </div>

            <!-- Desktop Navigation -->
            <nav class="header-nav-col desktop-nav">
              <ul class="main-menu">
                {navItems.map((item) => (
                  <li class={`menu-item${item.children ? ' has-submenu' : ''}${item.isHome ? ' current' : ''}${currentPath === item.href ? ' current' : ''}`}>
                    <a href={item.href} class="menu-link">
                      {item.label}
                      {item.children && <span class="submenu-arrow">▾</span>}
                    </a>
                    {item.children && (
                      <ul class="sub-menu">
                        {item.children.map((child) => (
                          <li><a href={child.href} class="sub-menu-link">{child.label}</a></li>
                        ))}
                      </ul>
                    )}
                  </li>
                ))}
              </ul>
            </nav>

            <!-- Actions: CTA + Search -->
            <div class="header-actions-col">
              <a href="/contacto" class="header-cta-btn">Presupuesto</a>
              <button class="header-search-btn" aria-label="Buscar">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
              </button>
            </div>

            <!-- Mobile Toggle -->
            <button class="mobile-toggle" aria-label="Menú" id="mobile-toggle">
              <span></span><span></span><span></span>
            </button>
          </div>
        </div>
      </div>

      <!-- Mobile Menu Panel -->
      <div class="mobile-menu-panel" id="mobile-panel">
        <div class="mobile-menu-inner">
          {navItems.map((item) => (
            <div>
              <a href={item.href} class="mobile-menu-link">{item.label}</a>
              {item.children && item.children.map((child) => (
                <a href={child.href} class="mobile-menu-sublink">{child.label}</a>
              ))}
            </div>
          ))}
          <a href="/contacto" class="mobile-cta-btn">Solicitar presupuesto</a>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <!-- Footer placeholder - next step -->
    <footer class="site-footer">
      <div class="footer-container">
        <p style="color:white;text-align:center;padding:40px">Footer — paso 2</p>
      </div>
    </footer>

    <script>
      document.getElementById('mobile-toggle')?.addEventListener('click', () => {
        document.getElementById('mobile-panel')?.classList.toggle('open');
      });
    </script>
  </body>
</html>

<style is:global>
  /* ===== HEADER CSS (cloned from Blocksy) ===== */
  
  .header-blocksy {
    --header-height: 140px;
    position: sticky;
    top: 0;
    z-index: 50;
  }
  
  .header-sticky {
    position: relative;
  }
  
  /* Top Row */
  .header-top-row {
    background: var(--palette-7); /* #00312D */
    height: 40px;
    display: flex;
    align-items: center;
  }
  
  .header-container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 35px;
    width: 100%;
  }
  
  .header-top-content {
    display: flex;
    justify-content: flex-start;
    width: 100%;
  }
  
  .header-contact-text {
    font-family: var(--font-body);
    font-weight: 100;
    font-size: 13px;
    line-height: 1;
    color: #ffffff;
    max-width: 50%;
  }
  
  .header-contact-text a {
    color: #ffffff;
    text-decoration: none;
  }
  
  .header-contact-text a:hover {
    color: var(--palette-3);
  }
  
  /* Middle Row */
  .header-middle-row {
    height: 100px;
    background: var(--palette-8);
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--palette-8);
  }
  
  .header-middle-grid {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 30px;
    width: 100%;
  }
  
  /* Logo */
  .header-logo-col {
    display: flex;
    align-items: center;
  }
  
  .site-logo-container img {
    max-height: 75px;
    width: auto;
    display: block;
  }
  
  /* Desktop Navigation */
  .desktop-nav {
    display: flex;
    justify-content: center;
  }
  
  .main-menu {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 5px;
  }
  
  .menu-item {
    position: relative;
  }
  
  .menu-link {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 8px 14px;
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: 18px;
    text-transform: capitalize;
    color: var(--palette-7);
    text-decoration: none;
    transition: color 0.2s;
    white-space: nowrap;
  }
  
  .menu-link:hover,
  .menu-item.current > .menu-link {
    color: var(--palette-3);
  }
  
  .submenu-arrow {
    font-size: 10px;
    margin-left: 2px;
  }
  
  /* Sub-menu dropdown */
  .sub-menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    background: var(--palette-2);
    min-width: 320px;
    list-style: none;
    margin: 0;
    padding: 8px 0;
    border-radius: 0 0 2px 2px;
    box-shadow: 0 10px 20px rgba(41,51,61,0.1);
    z-index: 100;
  }
  
  .menu-item.has-submenu:hover .sub-menu {
    display: block;
  }
  
  .sub-menu li {
    border-bottom: 1px dashed rgba(255,255,255,0.1);
  }
  
  .sub-menu li:last-child {
    border-bottom: none;
  }
  
  .sub-menu-link {
    display: block;
    padding: 10px 20px;
    font-weight: 500;
    font-size: 16px;
    color: var(--palette-8);
    text-decoration: none;
    transition: color 0.2s;
  }
  
  .sub-menu-link:hover {
    color: var(--palette-6);
  }
  
  /* Header Actions */
  .header-actions-col {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  
  .header-cta-btn {
    display: inline-flex;
    align-items: center;
    background: var(--palette-3);
    color: var(--palette-8);
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: 15px;
    border: none;
    border-radius: 20px;
    padding: 5px 20px;
    min-height: 40px;
    text-decoration: none;
    transition: background 0.2s;
    white-space: nowrap;
  }
  
  .header-cta-btn:hover {
    background: var(--palette-2);
    color: var(--palette-7);
  }
  
  .header-search-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--palette-3);
    padding: 8px;
    display: flex;
    align-items: center;
  }
  
  .header-search-btn:hover {
    color: var(--palette-3);
  }
  
  /* Mobile Toggle */
  .mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 10px;
  }
  
  .mobile-toggle span {
    display: block;
    width: 18px;
    height: 2px;
    background: var(--palette-3);
    border-radius: 1px;
    transition: all 0.2s;
  }
  
  /* Mobile Panel */
  .mobile-menu-panel {
    display: none;
    background: rgba(18,21,25,0.98);
    max-height: calc(100vh - var(--header-height));
    overflow-y: auto;
  }
  
  .mobile-menu-panel.open {
    display: block;
  }
  
  .mobile-menu-inner {
    padding: 20px 35px;
  }
  
  .mobile-menu-link {
    display: block;
    padding: 12px 0;
    font-weight: 700;
    font-size: 20px;
    color: #ffffff;
    text-decoration: none;
    border-bottom: none;
  }
  
  .mobile-menu-sublink {
    display: block;
    padding: 8px 0 8px 20px;
    font-size: 16px;
    color: rgba(255,255,255,0.8);
    text-decoration: none;
  }
  
  .mobile-cta-btn {
    display: inline-block;
    margin-top: 20px;
    background: var(--palette-3);
    color: var(--palette-8);
    padding: 12px 24px;
    border-radius: 20px;
    font-weight: 700;
    font-size: 16px;
    text-decoration: none;
  }
  
  /* Responsive */
  @media (max-width: 1000px) {
    .desktop-nav { display: none; }
    .header-actions-col { display: none; }
    .mobile-toggle { display: flex; }
    .header-middle-grid { grid-template-columns: 1fr auto; }
  }
  
  @media (max-width: 690px) {
    .header-container { padding: 0 20px; }
    .header-contact-text { font-size: 14px; }
    .header-middle-row { height: 80px; }
  }
</style>
